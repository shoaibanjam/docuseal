# Trustseal production environment
# Copy to .env and fill in values: cp .env.example .env

# Required: PostgreSQL (use host.docker.internal when DB runs on same EC2)
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/docuseal

# Required: generate with: openssl rand -hex 64
SECRET_KEY_BASE=

# Required: your domain or EC2 public IP (used in links and emails)
HOST=localhost

# Recommended when behind HTTPS (e.g. Caddy/nginx)
FORCE_SSL=false

# Optional: for email links (defaults to HOST)
# EMAIL_HOST=your-domain.com

# Optional: external Redis (omit to use in-container Redis)
# REDIS_URL=redis://:password@host:6379/0

# Optional: AWS Secrets Manager (replaces SECRET_KEY_BASE and other vars from secret)
# AWS_SECRET_MANAGER_ID=your-secret-id

# Optional: S3 for attachments (omit to use disk storage in volume)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_ATTACHMENTS_BUCKET=

# Optional: skip auto migrations on boot (default: migrations run)
# RUN_MIGRATIONS=false
