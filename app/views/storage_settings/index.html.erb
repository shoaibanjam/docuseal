<div class="settings-layout profile-settings-page storage-settings-page">
  <div class="settings-main profile-settings-main">
    <header class="settings-page-header profile-settings-header storage-settings-header">
      <div class="settings-page-header-top">
        <div class="settings-page-avatar profile-settings-avatar storage-settings-page__avatar" aria-hidden="true">
          <%= svg_icon('files', class: 'w-7 h-7 shrink-0') %>
        </div>
        <div class="profile-settings-header-text">
          <p class="storage-settings-eyebrow">
            <%= t('storage_settings_eyebrow', default: 'Infrastructure') %>
          </p>
          <h1 class="ds-heading-2 profile-settings-title">
            <%= t('storage') %>
          </h1>
          <p class="settings-page-subtitle profile-settings-intro">
            <%= t('storage_settings_intro', default: 'Choose where signed documents, uploads, and attachments are stored for your workspace.') %>
          </p>
        </div>
      </div>
    </header>

    <% value = @encrypted_config.value || { 'service' => 'disk' } %>
    <% configs = value['configs'] || {} %>
    <%= form_for @encrypted_config, url: settings_storage_index_path, method: :post, html: { autocomplete: 'off', class: 'storage-settings-form' } do |f| %>
      <% options = [%w[Disk disk], %w[AWS aws_s3], %w[GCP google], %w[Azure azure]] %>
      <div class="settings-profile-columns profile-settings-grid storage-settings-two-column">
        <div class="settings-profile-main profile-settings-column profile-settings-column--storage-backend min-w-0">
          <section class="settings-card profile-settings-card profile-settings-card--storage-backend">
            <div class="settings-card-header">
              <div>
                <h2 id="storage-backend-heading" class="settings-card-title flex items-center gap-2.5">
                  <%= svg_icon('cloud_upload', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
                  <span><%= t('storage_backend_panel_title', default: 'Backend') %></span>
                </h2>
                <p class="settings-card-subtitle">
                  <%= t('storage_backend_panel_hint', default: 'Select where files are stored. You can switch providers anytime.') %>
                </p>
              </div>
            </div>
            <div
              class="storage-provider-picker"
              role="radiogroup"
              aria-labelledby="storage-backend-heading"
            >
              <toggle-visible data-element-ids="<%= options.map(&:last).to_json %>" class="block relative">
                <ul class="storage-provider-picker-list">
                  <% options.each do |(label, val)| %>
                    <li class="storage-provider-option-row">
                      <%= f.radio_button :selected, val, checked: value['service'] == val, id: "#{val}_radio", data: { action: 'change:toggle-visible#trigger' }, class: 'storage-provider-radio base-radio shrink-0' %>
                      <%= f.label :selected, label, value: val, for: "#{val}_radio", class: 'storage-provider-option-label' %>
                    </li>
                  <% end %>
                </ul>
              </toggle-visible>
            </div>
          </section>
        </div>

        <aside class="settings-profile-secondary profile-settings-column profile-settings-column--storage-fields min-w-0">
          <section class="settings-card profile-settings-card profile-settings-card--storage-fields">
            <div class="settings-card-header">
              <div>
                <h2 class="settings-card-title flex items-center gap-2.5">
                  <%= svg_icon('adjustments_horizontal', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
                  <span><%= t('storage_configuration_panel_title', default: 'Configuration') %></span>
                </h2>
                <p class="settings-card-subtitle">
                  <%= t('storage_configuration_panel_hint', default: 'Credentials and options for the backend selected on the left.') %>
                </p>
              </div>
            </div>

            <div class="storage-settings-fields-stack space-y-0">
              <disable-hidden id="disk" class="storage-settings-panel <%= 'hidden' if value['service'] != 'disk' %>">
                <%= render 'disk_form', f: %>
              </disable-hidden>
              <disable-hidden id="aws_s3" class="storage-settings-panel space-y-6 <%= 'hidden' if value['service'] != 'aws_s3' %>">
                <%= render 'aws_form', f:, configs:, value: %>
              </disable-hidden>
              <disable-hidden id="google" class="storage-settings-panel space-y-6 <%= 'hidden' if value['service'] != 'google' %>">
                <%= render 'google_cloud_form', f:, configs:, value: %>
              </disable-hidden>
              <disable-hidden id="azure" class="storage-settings-panel space-y-6 <%= 'hidden' if value['service'] != 'azure' %>">
                <%= render 'azure_form', f:, configs:, value: %>
              </disable-hidden>
            </div>

            <div class="settings-card-actions profile-settings-card-actions storage-settings-save mt-8">
              <%= f.button button_title(
                    title: t('save'),
                    disabled_with: t('saving'),
                    icon: svg_icon('save', class: 'w-4 h-4')
                  ),
                  class: 'base-button profile-settings-btn-primary w-full flex items-center justify-center gap-2' %>
            </div>
          </section>
        </aside>
      </div>
    <% end %>
  </div>
</div>
