<%= f.fields_for :value do |ff| %>
  <%= ff.hidden_field :service, value: 'google' %>
  <%= ff.fields_for :configs, configs do |fff| %>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="form-control">
        <%= fff.label :project, 'Project', class: 'label' %>
        <%= fff.text_field :project,
          value: configs['project'],
          required: true,
          class: 'base-input',
          placeholder: t('storage_placeholder_gcp_project', default: 'my-gcp-project-id') %>
      </div>
      <div class="form-control">
        <%= fff.label :bucket, class: 'label' %>
        <%= fff.text_field :bucket,
          value: value['service'] == 'google' ? configs['bucket'] : '',
          required: true,
          class: 'base-input',
          placeholder: t('storage_placeholder_gcp_bucket', default: 'my-bucket-name') %>
      </div>
    </div>
    <div class="form-control">
      <%= fff.label :credentials, 'Credentials (JSON key content)', class: 'label' %>
      <%= fff.text_area :credentials,
        required: true,
        class: 'base-textarea w-full font-mono',
        rows: 6,
        placeholder: configs['credentials'].present? ? t('storage_placeholder_gcp_credentials_saved', default: '{ **REDACTED** }') : t('storage_placeholder_gcp_credentials', default: 'Paste the full JSON from your GCP service account key file.'),
        spellcheck: false %>
    </div>
  <% end %>
<% end %>
