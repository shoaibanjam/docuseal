<%= f.fields_for :value do |ff| %>
  <%= ff.hidden_field :service, value: 'disk' %>
<% end %>
<div class="alert storage-disk-callout storage-disk-callout--notice">
  <span class="storage-disk-callout-icon" aria-hidden="true">
    <%= svg_icon('info_circle', class: 'stroke-current flex-shrink-0 w-6 h-6') %>
  </span>
  <div class="storage-disk-callout-body min-w-0">
    <p class="storage-disk-title">
      <%= t('store_all_files_on_disk') %>
    </p>
    <p class="storage-disk-description">
      <%= t('no_configs_are_needed_but_make_sure_your_disk_is_persistent') %>
      <br>
      <i>(<%= t('not_suitable_for_heroku_and_other_paas') %>)</i>
    </p>
  </div>
</div>
