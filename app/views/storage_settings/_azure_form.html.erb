<%= f.fields_for :value do |ff| %>
  <%= ff.hidden_field :service, value: 'azure' %>
  <%= ff.fields_for :configs, configs do |fff| %>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="form-control">
        <%= fff.label :storage_account_name, 'Storage Account Name', class: 'label' %>
        <%= fff.text_field :storage_account_name,
          value: configs['storage_account_name'],
          required: true,
          class: 'base-input',
          placeholder: t('storage_placeholder_azure_account', default: 'mystorageaccount'),
          autocomplete: 'off' %>
      </div>
      <div class="form-control">
        <%= fff.label :container, class: 'label' %>
        <%= fff.text_field :container,
          value: configs['container'],
          required: true,
          class: 'base-input',
          placeholder: t('storage_placeholder_azure_container', default: 'documents') %>
      </div>
    </div>
    <div class="form-control">
      <%= fff.label :storage_access_key, 'Storage Access Key', class: 'label' %>
      <%= fff.password_field :storage_access_key,
        required: true,
        class: 'base-input',
        autocomplete: 'new-password',
        placeholder: configs['storage_access_key'].present? ? t('storage_placeholder_secret_saved', default: 'Leave blank to keep existing secret') : t('storage_placeholder_azure_key', default: '••••••••••••') %>
    </div>
  <% end %>
<% end %>
