<% filter_params = params.permit(Submissions::Filter::ALLOWED_PARAMS).compact_blank %>
<% is_show_tabs = (@pagy.count.nil? || @pagy.count >= 5) || params[:status].present? || filter_params.present? %>
<% if Docuseal.demo? %><%= render 'shared/demo_alert' %><% end %>
<div class="space-y-5">
  <div class="flex justify-between items-center w-full">
    <div class="flex items-center flex-grow min-w-0 text-primary-content">
      <div class="mr-2">
        <%= render 'dashboard/toggle_view', selected: 'submissions' %>
      </div>
      <div>
        <h1 class="text-2xl truncate md:text-3xl sm:text-4xl font-bold md:block <%= 'hidden' if params[:q].present? %>">
          <%= t('submissions') %>
        </h1>
        <p class="text-sm text-primary-content/70">
          Manage and monitor digital verification requests.
        </p>
      </div>
    </div>
    <div class="flex space-x-2">
      <% if params[:q].present? || @pagy.pages > 1 || filter_params.present? %>
        <%= render 'shared/search_input' %>
      <% end %>
      <% if can?(:create, ::Template) %>
        <span class="hidden sm:block">
          <%= render 'templates/upload_button' %>
        </span>
        <%= link_to new_template_path, class: 'base-button gap-2', data: { turbo_frame: :modal } do %>
          <%= svg_icon('plus', class: 'w-6 h-6 stroke-2') %>
          <span class="hidden md:block"><%= t('create') %></span>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="overflow-x-auto mt-6 mb-7 md:mt-8 md:mb-10">
    <div class="flex flex-nowrap gap-4 min-w-[900px]">
      <div class="ds-submissions-stat-card relative bg-[#0d1c2f] rounded-xl border border-white/10 p-5 flex-1 min-w-[210px] overflow-hidden">
        <span class="absolute left-0 top-0 bottom-0 w-1 bg-secondary"></span>
        <div class="text-xs uppercase tracking-wider text-primary-content/60">Total Active</div>
        <div class="text-3xl font-bold mt-1"><%= number_with_delimiter(@stats_total) %></div>
      </div>
      <div class="ds-submissions-stat-card relative bg-[#0d1c2f] rounded-xl border border-white/10 p-5 flex-1 min-w-[210px] overflow-hidden">
        <span class="absolute left-0 top-0 bottom-0 w-1 bg-[#35d0af]"></span>
        <div class="text-xs uppercase tracking-wider text-primary-content/60"><%= t('completed') %></div>
        <div class="text-3xl font-bold mt-1"><%= number_with_delimiter(@stats_completed) %></div>
      </div>
      <div class="ds-submissions-stat-card relative bg-[#0d1c2f] rounded-xl border border-white/10 p-5 flex-1 min-w-[210px] overflow-hidden">
        <span class="absolute left-0 top-0 bottom-0 w-1 bg-[#f3b565]"></span>
        <div class="text-xs uppercase tracking-wider text-primary-content/60"><%= t('awaiting') %></div>
        <div class="text-3xl font-bold mt-1"><%= number_with_delimiter(@stats_awaiting) %></div>
      </div>
      <div class="ds-submissions-stat-card relative bg-[#0d1c2f] rounded-xl border border-white/10 p-5 flex-1 min-w-[210px] overflow-hidden">
        <span class="absolute left-0 top-0 bottom-0 w-1 bg-[#60708a]"></span>
        <div class="text-xs uppercase tracking-wider text-primary-content/60">Avg. Time</div>
        <div class="text-3xl font-bold mt-1"><%= @stats_avg_time %></div>
      </div>
    </div>
  </div>

  <% view_archived_html = capture do %>
    <% if can?(:manage, :countless) || current_account.submissions.where.not(archived_at: nil).exists? %>
      <div>
        <a href="<%= submissions_archived_index_path %>" class="link text-sm"><%= t('view_archived') %></a>
      </div>
    <% end %>
  <% end %>

  <% if is_show_tabs %>
    <div class="flex items-center flex-col md:flex-row md:flex-wrap gap-2 mt-4 md:mt-6">
      <div class="flex items-center md:items-end flex-col md:flex-row gap-2 w-full md:w-fit">
        <a href="<%= url_for(params: request.query_parameters.except('status')) %>" class="ds-submissions-tab <%= params[:status].blank? ? 'border-secondary bg-secondary/10' : 'border-white/10' %> flex h-10 px-3 py-1 text-sm md:text-base items-center justify-between border text-center text-primary-content font-semibold rounded-xl w-full md:w-44 hover:border-secondary/70 bg-[#0d1c2f]">
          <div class="flex items-center space-x-1">
            <%= svg_icon('list', class: 'w-5 h-5') %>
            <span class="font-normal"><%= t('all') %></span>
          </div>
        </a>
        <a href="<%= url_for(params: request.query_parameters.merge('status' => 'pending')) %>" class="ds-submissions-tab <%= params[:status] == 'pending' ? 'border-secondary bg-secondary/10' : 'border-white/10' %> flex h-10 px-3 py-1 text-sm md:text-base items-center justify-between border text-center text-primary-content font-semibold rounded-xl w-full md:w-44 hover:border-secondary/70 bg-[#0d1c2f]">
          <div class="flex items-center space-x-1">
            <%= svg_icon('clock', class: 'w-5 h-5') %>
            <span class="font-normal"><%= t('pending') %></span>
          </div>
        </a>
        <a href="<%= url_for(params: request.query_parameters.merge('status' => 'completed')) %>" class="ds-submissions-tab <%= params[:status] == 'completed' ? 'border-secondary bg-secondary/10' : 'border-white/10' %> flex h-10 px-3 py-1 text-sm md:text-base items-center justify-between border text-center text-primary-content font-semibold rounded-xl w-full md:w-44 hover:border-secondary/70 bg-[#0d1c2f]">
          <div class="flex items-center space-x-1">
            <%= svg_icon('circle_check', class: 'w-5 h-5') %>
            <span class="font-normal"><%= t('completed') %></span>
          </div>
        </a>
      </div>
      <div class="flex items-end flex-col md:flex-row gap-2 w-full md:w-fit">
        <%= render 'submissions_filters/applied_filters', filter_params: %>
        <%= render 'submissions_filters/filter_button', filter_params: %>
        <%= render 'submissions_filters/actions', filter_params: %>
      </div>
    </div>
  <% end %>

  <% if @pagy.count.nil? || @pagy.count > 0 %>
    <div class="ds-submissions-list-shell bg-[#08192d] border border-white/10 rounded-2xl p-3 md:p-4">
      <div class="hidden md:flex items-center px-4 pb-2 text-[11px] uppercase tracking-wider text-primary-content/50">
        <div class="w-52 px-1">Submission Details</div>
        <div class="flex-1 flex items-center justify-between px-6">
          <div>Status</div>
          <div class="text-right">Actions</div>
        </div>
      </div>
      <div class="space-y-3">
        <%= render partial: 'templates/submission', collection: @submissions, locals: { with_template: true } %>
      </div>
    </div>
  <% end %>
  <% if params[:q].blank? && params[:status].blank? && filter_params.blank? && @pagy.count.present? && @pagy.count < 5 %>
    <%= render 'templates/dropzone' %>
  <% end %>
  <% if @submissions.present? || (params[:q].blank? && filter_params.blank?) %>
    <% if @pagy.pages > 1 %>
      <%= render 'shared/pagination', pagy: @pagy, items_name: 'submissions', left_additional_html: view_archived_html %>
    <% else %>
      <div class="mt-2">
        <%= view_archived_html %>
      </div>
    <% end %>
  <% elsif params[:q].present? || filter_params.present? %>
    <div class="text-center">
      <div class="mt-16 text-3xl font-semibold">
        <%= t('submissions_not_found') %>
      </div>
    </div>
  <% else %>
    <div class="text-center text-primary-content/70">
      <%= t('there_are_no_submissions') %>
    </div>
  <% end %>
</div>
