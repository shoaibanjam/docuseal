<div class="profile-settings-page auth-page">
  <div class="auth-shell">
    <div class="auth-card settings-card">
      <div class="auth-header">
        <h1 class="auth-title auth-title--sm"><%= t('change_your_password') %></h1>
      </div>
      <div class="tpl-new-form">
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
          <%= render 'devise/shared/error_messages', resource: %>
          <%= f.hidden_field :reset_password_token %>
          <div class="form-control">
            <%= f.label :password, t('new_password'), class: 'label' %>
            <%= f.password_field :password, autofocus: true, autocomplete: 'new-password', class: 'base-input w-full', placeholder: t('profile_placeholder_new_password', default: '••••••••••••') %>
            <% if @minimum_password_length %>
              <label class="label">
                <span class="label-text">(<%= t('minimum_password_length_characters_minimum', minimum_password_length: @minimum_password_length) %>)</span>
              </label>
            <% end %>
          </div>
          <div class="form-control">
            <%= f.label :password_confirmation, t('confirm_new_password'), class: 'label' %>
            <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'base-input w-full', placeholder: t('profile_placeholder_confirm_password', default: '••••••••••••') %>
          </div>
          <div class="form-control">
            <%= f.button button_title(title: t('change_my_password'), disabled_with: t('changing_password')), class: 'base-button profile-settings-btn-primary tpl-new-submit-btn' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
