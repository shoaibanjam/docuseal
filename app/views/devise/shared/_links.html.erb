<div class="auth-card__links">
  <%- if controller_name != 'sessions' %>
    <%= link_to t('already_have_an_account'), new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'auth-card__link' %>
  <% end %>
  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to t('create_free_account'), new_user_registration_path({ redir: params[:redir], lang: params[:lang] }.compact_blank), class: 'auth-card__link' %>
  <% end %>
  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to t('forgot_your_password_'), new_user_password_path({ lang: params[:lang] }.compact_blank), class: 'auth-card__link' %>
  <% end %>
</div>
<div class="text-center">
  <%= form_with url: url_for, method: :get do %>
    <% if params[:redir].present? %>
      <%= hidden_field_tag :redir, params[:redir] %>
    <% end %>
    <submit-form data-on="change">
      <%= select_tag :lang, options_for_select((I18n.available_locales - %i[en pt-PT de-DE fr-FR it-IT es-ES nl-NL]).map { |code| [t("language_#{code}"), code] }, I18n.locale), class: 'base-select auth-card__language' %>
    </submit-form>
  <% end %>
</div>
