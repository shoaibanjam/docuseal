<% inline_fields = Array(local_assigns[:inline_fields]).map(&:to_sym) %>
<% banner_errors = resource.errors.reject { |error| inline_fields.include?(error.attribute) } %>
<% if banner_errors.any? %>
  <div id="error_explanation" data-turbo-cache="false">
    <div class="alert">
      <%= svg_icon('x_circle', class: 'stroke-current shrink-0 h-6 w-6') %>
      <div>
        <p class="font-bold">
          <%= I18n.t('errors.messages.not_saved',
                     count: banner_errors.size,
                     resource: resource.class.model_name.human.downcase) %></p>
        <% banner_errors.map(&:full_message).each do |message| %>
          <p class="text-sm"><%= message %></p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
