<%= content_for(:canonical_url, new_user_registration_url) %>
<div class="auth-shell">
  <div class="auth-card">
    <div class="auth-header">
      <h1 class="auth-title"><%= t('sign_up') %></h1>
    </div>
    <%= form_for(resource, as: resource_name, html: { class: 'space-y-6' }, data: { turbo: params[:redir].blank? }, url: registration_path(resource_name)) do |f| %>
      <%= render 'devise/shared/error_messages', resource: resource %>
      <%= render 'devise/sessions/hidden_fields' %>
      <div class="space-y-2" dir="auto">
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
          <div class="form-control">
            <%= f.label :first_name, t(:first_name), class: 'label' %>
            <%= f.text_field :first_name, autocomplete: 'given-name', class: 'base-input' %>
          </div>
          <div class="form-control">
            <%= f.label :last_name, t(:last_name), class: 'label' %>
            <%= f.text_field :last_name, autocomplete: 'family-name', class: 'base-input' %>
          </div>
        </div>
        <div class="form-control">
          <%= f.label :email, t(:email), class: 'label' %>
          <%= f.email_field :email, autofocus: true, autocomplete: 'email', class: 'base-input' %>
        </div>
        <div class="form-control">
          <%= f.label :password, t(:password), class: 'label' %>
          <%= f.password_field :password, autocomplete: 'new-password', class: 'base-input' %>
        </div>
        <div class="form-control">
          <%= f.label :password_confirmation, t(:confirm_new_password), class: 'label' %>
          <%= f.password_field :password_confirmation, autocomplete: 'new-password', class: 'base-input' %>
        </div>
      </div>
      <div class="form-control">
        <%= f.button button_title(title: t(:sign_up), disabled_with: t(:signing_up)), class: 'base-button w-full' %>
      </div>
    <% end %>
    <% if devise_mapping.omniauthable? && User.omniauth_providers.include?(:google_oauth2) %>
      <div class="pt-4 mt-2 border-t border-base-300/70 space-y-4">
        <%= form_for '', url: user_google_oauth2_omniauth_authorize_path, data: { turbo: false }, method: :post do |f| %>
          <set-timezone data-input-id="state" data-params="true"></set-timezone>
          <%= hidden_field_tag :state, { redir: params[:redir].to_s }.compact_blank.to_query %>
          <%= f.button button_title(title: t('sign_up_with_google'), icon: svg_icon('brand_google', class: 'w-6 h-6')), class: 'white-button w-full mt-1' %>
        <% end %>
      </div>
    <% end %>
    <div class="mt-6 space-y-3 text-sm text-primary-content/80">
      <%= render 'devise/shared/links' %>
    </div>
  </div>
</div>
