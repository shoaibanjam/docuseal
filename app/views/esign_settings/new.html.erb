<%= render 'shared/turbo_modal',
  title: t('upload_certificate'),
  enhanced_modal: true do %>
  <%= form_for @cert_record,
        url: settings_esign_path,
        html: { class: 'esign-upload-form', enctype: 'multipart/form-data' },
        data: { turbo_frame: :_top } do |f| %>
    <div class="esign-upload-editor">
      <p id="esign-upload-modal-description" class="signature-editor__lead esign-upload-editor__lead">
        <%= t('use_a_valid_der_p12_or_pfx_file') %>
      </p>
      <div class="esign-upload-fields">
        <div class="form-control">
          <%= f.label :name, t('name'), class: 'label' %>
          <%= f.text_field :name,
                required: true,
                class: 'base-input',
                placeholder: t('esign_placeholder_certificate_name'),
                aria: { describedby: 'esign-upload-modal-description' } %>
        </div>
        <div class="form-control">
          <%= f.label :file, t('file'), class: 'label' %>
          <%= f.file_field :file,
                required: true,
                class: 'file-input file-input-bordered w-full max-w-full',
                accept: '.der,.p12,.pfx,application/x-pkcs12',
                title: t('esign_upload_file_hint_title'),
                aria: { describedby: 'esign-upload-modal-description' } %>
        </div>
        <div class="form-control">
          <%= f.label :password, "#{t('password')} (#{t('optional')})", class: 'label' %>
          <%= f.password_field :password,
                class: 'base-input',
                autocomplete: 'new-password',
                placeholder: t('esign_placeholder_certificate_password') %>
        </div>
      </div>
      <div class="signature-editor__actions esign-upload-editor__actions">
        <button type="button" class="signature-editor__cancel btn btn-ghost" data-turbo-modal-close>
          <%= t('cancel', default: 'Cancel') %>
        </button>
        <%= f.button button_title(title: t('upload_certificate'), disabled_with: t('uploading')), class: 'base-button signature-editor__save' %>
      </div>
    </div>
  <% end %>
<% end %>
