<% has_archived = can?(:manage, :countless) || current_account.templates.where.not(archived_at: nil).exists? %>
<% show_dropzone = params[:q].blank? && @pagy.pages == 1 && ((@template_folders.size < 10 && @templates.size.zero?) || (@template_folders.size < 7 && @templates.size < 4) || (@template_folders.size < 4 && @templates.size < 7)) %>
<% if Docuseal.demo? %><%= render 'shared/demo_alert' %><% end %>
<div class="settings-layout profile-settings-page templates-dashboard-page folder-show-page">
  <div class="settings-main profile-settings-main templates-dashboard-main">
    <dashboard-dropzone class="templates-dashboard-dropzone block min-w-0">
      <%= form_for '', url: '', id: form_id = SecureRandom.uuid, method: :post, class: 'hidden', data: { target: 'dashboard-dropzone.form' }, html: { enctype: 'multipart/form-data' } do %>
        <input name="form_id" value="<%= form_id %>">
        <input name="folder_name" value="<%= @template_folder.full_name %>">
        <button type="submit"></button>
        <input id="dashboard_dropzone_input" name="files[]" type="file" multiple>
      <% end %>

      <header class="templates-dashboard-header relative w-full">
        <% unless show_dropzone %>
          <%= render 'templates/dashboard_dropzone', style: 'height: 114px' %>
        <% end %>
        <% unless @template_folder.parent_folder %>
          <%= render 'templates/dashboard_folder_dropzone', style: 'height: 114px' %>
        <% end %>

        <div class="settings-page-header profile-settings-header templates-dashboard-hero">
          <div class="settings-page-header-top templates-dashboard-header-top flex-col lg:flex-row lg:items-start lg:justify-between gap-6 lg:gap-8">
            <div class="flex gap-4 md:gap-5 items-start min-w-0 flex-1">
              <div class="settings-page-avatar profile-settings-avatar templates-dashboard-page__avatar shrink-0" aria-hidden="true">
                <%= svg_icon('folder', class: 'w-7 h-7 shrink-0') %>
              </div>
              <div class="profile-settings-header-text min-w-0">
                <div class="mb-2">
                  <%= link_to(@template_folder.parent_folder ? folder_path(@template_folder.parent_folder) : root_path, class: 'inline-flex items-center gap-1.5 text-sm font-medium link link-hover') do %>
                    <%= svg_icon('chevron_left', class: 'w-4 h-4 shrink-0') %>
                    <span><%= @template_folder.parent_folder&.name || t('home') %></span>
                  <% end %>
                </div>
                <p class="templates-dashboard-eyebrow">
                  <%= t('folder') %>
                </p>
                <div class="flex items-start gap-2 min-w-0 <%= 'hidden' if params[:q].present? %>">
                  <h1 class="ds-heading-2 profile-settings-title min-w-0 truncate md:whitespace-normal">
                    <%= @template_folder.name %>
                  </h1>
                  <% if can?(:update, @template_folder) && @template_folder.full_name != TemplateFolder::DEFAULT_NAME %>
                    <a href="<%= edit_folder_path(@template_folder) %>" data-turbo-frame="modal" class="tpl-show-icon-btn shrink-0 mt-0.5 hidden sm:inline-flex" aria-label="<%= t('rename') %>">
                      <%= svg_icon('pencil', class: 'w-4 h-4') %>
                    </a>
                  <% end %>
                </div>
                <p class="settings-page-subtitle profile-settings-intro templates-dashboard-intro <%= 'hidden' if params[:q].present? %>">
                  <%= t('folder_show_intro', default: 'Templates and subfolders in this location. Upload files or create a new document template.') %>
                </p>
              </div>
            </div>

            <div class="templates-dashboard-toolbar flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-3 w-full lg:w-auto lg:max-w-[26rem] xl:max-w-none shrink-0">
              <div class="templates-dashboard-actions flex flex-wrap items-center gap-2 justify-start sm:justify-end flex-1 min-w-[10rem]">
                <% if params[:q].present? || @pagy.pages > 1 || @template_folders.present? %>
                  <div class="flex-1 min-w-[12rem] max-w-full sm:max-w-xs md:max-w-sm">
                    <%= render 'shared/search_input' %>
                  </div>
                <% end %>
                <% if can?(:create, ::Template) %>
                  <span class="hidden sm:inline-flex templates-dashboard-upload-wrap">
                    <%= render 'templates/upload_button', folder_name: @template_folder.full_name %>
                  </span>
                  <%= link_to new_template_path(folder_name: @template_folder.full_name), class: 'base-button profile-settings-btn-primary gap-2 whitespace-nowrap shrink-0', data: { turbo_frame: :modal } do %>
                    <%= svg_icon('plus', class: 'w-5 h-5 stroke-2 shrink-0') %>
                    <span class="hidden md:inline"><%= t('create') %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </header>

      <% view_archived_html = capture do %>
        <% if has_archived %>
          <div class="templates-dashboard-archived-link">
            <a href="<%= templates_archived_index_path %>" class="link link-hover text-sm font-medium">
              <%= t('view_archived') %>
            </a>
          </div>
        <% end %>
      <% end %>
      <% templates_order_select_html = capture do %>
        <% if params[:q].blank? && @pagy.pages > 1 && @templates.present? %>
          <%= render 'shared/templates_order_select', with_recently_used: @pagy.count.present? && @pagy.count < 10_000 && !can?(:manage, :countless), selected_order: %>
        <% end %>
      <% end %>

      <% if @template_folders.present? %>
        <section class="templates-dashboard-section templates-dashboard-section--folders" aria-labelledby="folder-show-folders-heading">
          <div class="templates-dashboard-section-head">
            <h2 id="folder-show-folders-heading" class="templates-dashboard-section-title">
              <%= t('templates_dashboard_folders_heading', default: 'Folders') %>
            </h2>
          </div>
          <div class="templates-dashboard-grid templates-dashboard-grid--folders grid gap-5 md:gap-6 md:grid-cols-2 xl:grid-cols-3 <%= 'mb-8 md:mb-10' if @templates.present? %>">
            <%= render partial: 'template_folders/folder', collection: @template_folders, as: :folder %>
          </div>
        </section>
      <% end %>

      <% if @templates.present? %>
        <section class="templates-dashboard-section templates-dashboard-section--templates" aria-labelledby="folder-show-templates-heading">
          <div class="templates-dashboard-section-head">
            <h2 id="folder-show-templates-heading" class="templates-dashboard-section-title">
              <%= @template_folders.present? ? t('templates_dashboard_templates_heading', default: 'Templates') : t('templates_dashboard_recent_heading', default: 'Recent uploads') %>
            </h2>
          </div>
          <div class="templates-dashboard-grid templates-dashboard-grid--templates grid gap-5 md:gap-6 md:grid-cols-2 xl:grid-cols-3">
            <%= render partial: 'templates/template', collection: @templates %>
          </div>
        </section>
      <% end %>
    </dashboard-dropzone>

    <% if show_dropzone %>
      <%= render 'templates/dropzone' %>
    <% end %>

    <% if @templates.present? || @template_folders.present? || params[:q].blank? %>
      <% if @pagy.pages > 1 %>
        <div class="templates-dashboard-pagination-wrap pt-6 mt-2 md:mt-4">
          <%= render 'shared/pagination', pagy: @pagy, items_name: @templates.present? ? 'templates' : 'template_folders', left_additional_html: view_archived_html, right_additional_html: templates_order_select_html %>
        </div>
      <% else %>
        <div class="templates-dashboard-footer-meta mt-6 md:mt-8 flex flex-wrap items-center gap-x-4 gap-y-2">
          <%= view_archived_html %>
        </div>
      <% end %>
    <% elsif params[:q].present? %>
      <div class="templates-dashboard-empty-state settings-card profile-settings-card rounded-2xl px-6 py-12 md:py-14 md:px-10 text-center max-w-xl mx-auto mt-6 md:mt-10">
        <div class="templates-dashboard-empty-icon mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl border">
          <%= svg_icon('search', class: 'w-7 h-7 templates-dashboard-empty-icon-svg') %>
        </div>
        <p class="templates-dashboard-empty-title text-lg md:text-xl font-semibold tracking-tight">
          <%= t('templates_not_found') %>
        </p>
        <p class="templates-dashboard-empty-hint mt-2 text-sm leading-relaxed">
          <%= t('templates_dashboard_empty_search_hint', default: 'Try another keyword or clear search to see all templates.') %>
        </p>
        <div class="mt-6">
          <a href="<%= url_for(params: request.query_parameters.except('q')) %>" class="base-button profile-settings-btn-primary inline-flex items-center justify-center gap-2">
            <%= t('clear') %>
          </a>
        </div>
      </div>
      <% if @related_submissions.present? %>
        <section class="templates-dashboard-related mt-10 md:mt-14" aria-labelledby="folder-show-related-submissions">
          <div class="templates-dashboard-section-head mb-4 md:mb-5">
            <h2 id="folder-show-related-submissions" class="templates-dashboard-section-title">
              <%= t('submissions') %>
            </h2>
          </div>
          <div class="space-y-4">
            <%= render partial: 'templates/submission', collection: @related_submissions, locals: { with_template: true } %>
          </div>
          <%= render 'shared/pagination', pagy: @related_submissions_pagy, items_name: 'submissions', next_page_path: submissions_path(q: params[:q], folder: @template_folder.full_name) %>
        </section>
      <% end %>
    <% end %>
  </div>
</div>
<%= render 'shared/review_form' %>
