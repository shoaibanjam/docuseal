<div class="settings-layout profile-settings-page api-settings-page">
  <div class="settings-main profile-settings-main">
    <header class="settings-page-header profile-settings-header api-settings-header">
      <div class="settings-page-header-top">
        <div class="settings-page-avatar profile-settings-avatar api-settings-page__avatar" aria-hidden="true">
          <%= svg_icon('api', class: 'w-7 h-7 shrink-0') %>
        </div>
        <div class="profile-settings-header-text">
          <p class="api-settings-eyebrow">
            <%= t('api_settings_eyebrow', default: 'REST API') %>
          </p>
          <h1 class="ds-heading-2 profile-settings-title">
            <%= t('api') %>
          </h1>
          <p class="settings-page-subtitle profile-settings-intro api-settings-intro">
            <%= t(
                  'api_settings_intro',
                  default: 'Authenticate requests with your secret token and explore common curl examples below.'
                ) %>
          </p>
        </div>
      </div>
    </header>

    <div class="api-settings-toolbar mt-6 flex flex-wrap items-center justify-end gap-4">
      <%= render 'shared/test_mode_toggle' %>
    </div>

    <div class="api-settings-stack mt-8 space-y-6">
      <section class="settings-card profile-settings-card api-settings-card--token">
        <div class="settings-card-header">
          <div>
            <h2 class="settings-card-title flex items-center gap-2.5">
              <%= svg_icon('lock', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
              <span><%= t('x_auth_token', default: 'X-Auth-Token') %></span>
            </h2>
            <p class="settings-card-subtitle">
              <%= t(
                    'api_settings_token_hint',
                    default: 'Use this value in the X-Auth-Token header. Rotate if it may have been exposed.'
                  ) %>
            </p>
          </div>
        </div>
        <div class="api-settings-token-fields space-y-4">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-stretch lg:gap-4">
            <div class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row sm:items-stretch sm:gap-3">
              <% token = current_user.access_token.token %>
              <% obscured_token = current_user.access_token.token.sub(token[5..], '*' * token[5..].size) %>
              <% if current_account.testing? %>
                <masked-input class="block min-w-0 flex-1" data-token="<%= token %>">
                  <input id="api_key"
                         type="text"
                         value="<%= obscured_token %>"
                         class="base-input w-full font-mono"
                         autocomplete="off"
                         readonly>
                </masked-input>
                <%= render 'shared/clipboard_copy',
                      icon: 'copy',
                      text: token,
                      always_show_label: true,
                      class: 'base-button profile-settings-btn-primary inline-flex cursor-pointer items-center justify-center gap-2 px-5 py-0 shrink-0 sm:self-stretch',
                      icon_class: 'w-5 h-5 shrink-0',
                      copy_title: t('copy'),
                      copied_title: t('copied') %>
              <% else %>
                <a id="access_token_container"
                   href="<%= settings_reveal_access_token_path %>"
                   data-turbo-frame="modal"
                   class="flex min-w-0 flex-1 flex-col gap-3 sm:flex-row sm:items-stretch sm:gap-3">
                  <input id="api_key"
                         type="text"
                         value="<%= obscured_token %>"
                         class="base-input w-full font-mono"
                         autocomplete="off"
                         readonly>
                  <div class="base-button profile-settings-btn-primary inline-flex min-h-[2.75rem] shrink-0 cursor-pointer items-center justify-center gap-2 px-5 sm:self-stretch">
                    <%= svg_icon('copy', class: 'w-5 h-5 shrink-0') %>
                    <span class="inline tracking-wide"><%= t('copy') %></span>
                  </div>
                </a>
              <% end %>
            </div>
            <%= button_to button_title(title: t('rotate'), disabled_with: t('rotate'), icon: svg_icon('reload', class: 'w-5 h-5')),
                  settings_api_index_path,
                  id: 'rotate_api_token_button',
                  class: 'white-button profile-settings-btn-outline inline-flex min-h-[2.75rem] w-full shrink-0 items-center justify-center gap-2 px-5 tracking-wide readable-disabled lg:w-auto lg:min-w-[10rem]',
                  data: { turbo_confirm: t('remove_existing_api_token_and_generated_a_new_one_are_you_sure_') } %>
          </div>
        </div>
      </section>

      <div class="api-docs-list space-y-4">
        <div class="collapse collapse-plus overflow-visible api-settings-docs-collapse px-1 api-docs-item">
          <input type="checkbox">
          <div class="collapse-title text-xl font-medium api-docs-title">
            <div>
              <%= t('request_signature_multiple_submitters_with_default_values') %>
            </div>
            <div class="mt-1">
              <div class="badge badge-warning badge-lg api-docs-method">POST</div>
              <div class="badge badge-primary badge-lg api-docs-endpoint"><%= api_submissions_path %></div>
            </div>
          </div>
          <div class="collapse-content api-docs-content" style="display: inherit">
            <div class="mockup-code overflow-hidden api-docs-code">
              <% text = capture do %>curl --location '<%= api_submissions_url %>' \
       --header 'X-Auth-Token: API_TOKEN' \
       --data-raw '{
         "template_id": <%= current_account.templates.last&.id || 1 %>,
         "submitters": [
           {
             "name": "John Doe",
             "role": "<%= current_account.templates.last ? current_account.templates.last.submitters.first['name'] : 'First Party' %>",
             "email": "<%= current_user.email.sub('@', '+test@') %>",
             "values": {
               "Form Text Field Name": "Default Value"
             }
           },
           { "role": "Second Submitter", "email": "<%= current_user.email.sub('@', '+test2@') %>" }
         ]
       }'<% end.to_str %>
              <span class="absolute right-0 top-0">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-ghost api-docs-copy-btn', icon_class: 'w-6 h-6', copy_title: t('copy'), copied_title: t('copied') %>
              </span>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--dark overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--dark block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--light overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--light block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.light') %></code></pre>
            </div>
          </div>
        </div>
        <div class="collapse collapse-plus overflow-visible api-settings-docs-collapse px-1 api-docs-item">
          <input type="checkbox">
          <div class="collapse-title text-xl font-medium api-docs-title">
            <div>
              <%= t('request_signature_single_submitter') %>
            </div>
            <div class="mt-1">
              <div class="badge badge-warning badge-lg api-docs-method">POST</div>
              <div class="badge badge-primary badge-lg api-docs-endpoint"><%= api_submissions_emails_path %></div>
            </div>
          </div>
          <div class="collapse-content api-docs-content" style="display: inherit">
            <div class="mockup-code overflow-hidden api-docs-code">
              <% text = capture do %>curl --location '<%= api_submissions_emails_url %>' \
       --header 'X-Auth-Token: API_TOKEN' \
       --data-raw '{
           "template_id": <%= current_account.templates.last&.id || 1 %>,
           "emails":  "<%= current_user.email.sub('@', '+test@') %>, <%= current_user.email.sub('@', '+test2@') %>"
       }'<% end.to_str %>
              <span class="absolute right-0 top-0">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-ghost api-docs-copy-btn', icon_class: 'w-6 h-6', copy_title: t('copy'), copied_title: t('copied') %>
              </span>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--dark overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--dark block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--light overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--light block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.light') %></code></pre>
            </div>
          </div>
        </div>
        <div class="collapse collapse-plus overflow-visible api-settings-docs-collapse px-1 api-docs-item">
          <input type="checkbox">
          <div class="collapse-title text-xl font-medium api-docs-title">
            <div>
              <%= t('template_details') %>
            </div>
            <div class="mt-1">
              <div class="badge badge-info badge-lg api-docs-method">GET</div>
              <div class="badge badge-primary badge-lg api-docs-endpoint"><%= api_template_path(':id') %></div>
            </div>
          </div>
          <div class="collapse-content api-docs-content" style="display: inherit">
            <div class="mockup-code overflow-hidden api-docs-code">
              <% text = capture do %>curl '<%= api_template_url(current_account.templates&.last || 1) %>' \
       --header 'X-Auth-Token: API_TOKEN'<% end.to_str %>
              <span class="absolute right-0 top-0">
                <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'btn btn-ghost api-docs-copy-btn', icon_class: 'w-6 h-6', copy_title: t('copy'), copied_title: t('copied') %>
              </span>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--dark overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--dark block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></code></pre>
              <pre data-prefix="$" class="api-docs-pre api-docs-pre--light overflow-x-auto"><code class="api-docs-code-content api-docs-code-content--light block min-w-max"><%== HighlightCode.call(text, 'Shell', theme: 'base16.light') %></code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
