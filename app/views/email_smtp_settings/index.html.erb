<div class="settings-layout profile-settings-page smtp-settings-page">
  <div class="settings-main profile-settings-main">
    <header class="settings-page-header profile-settings-header smtp-settings-header">
      <div class="settings-page-header-top">
        <div class="settings-page-avatar profile-settings-avatar smtp-settings-page__avatar" aria-hidden="true">
          <%= svg_icon('mail', class: 'w-7 h-7 shrink-0') %>
        </div>
        <div class="profile-settings-header-text">
          <p class="smtp-settings-eyebrow">
            <%= t('smtp_settings_eyebrow', default: 'Outbound mail') %>
          </p>
          <h1 class="ds-heading-2 profile-settings-title">
            <%= t('email_smtp_configuration', default: 'Email SMTP Configuration') %>
          </h1>
          <p class="settings-page-subtitle profile-settings-intro">
            <%= t('manage_outgoing_email_server_settings', default: 'Manage your outgoing email server settings for notifications and document delivery.') %>
          </p>
        </div>
      </div>
    </header>

    <% value = @email_smtp_form_value %>
    <%= form_for @encrypted_config, url: settings_email_index_path, method: :post, html: { autocomplete: 'off', class: 'smtp-settings-form' } do |f| %>
      <%= f.fields_for :value do |ff| %>
        <div class="settings-profile-columns profile-settings-grid">
          <div class="settings-profile-main profile-settings-column profile-settings-column--primary">
            <section class="settings-card profile-settings-card profile-settings-card--smtp-credentials">
              <div class="settings-card-header">
                <div>
                  <h2 class="settings-card-title flex items-center gap-2.5">
                    <%= svg_icon('mail', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
                    <span><%= t('server_credentials', default: 'Server Credentials') %></span>
                  </h2>
                  <p class="settings-card-subtitle">
                    <%= t('smtp_server_credentials_hint', default: 'Host, port, and login used to connect to your outgoing mail server.') %>
                  </p>
                </div>
              </div>

              <div class="smtp-field-group">
                <p class="smtp-field-group-label" id="smtp-group-connection">
                  <%= t('smtp_subgroup_connection', default: 'Connection') %>
                </p>
                <div class="grid gap-6 md:grid-cols-2">
                  <div class="form-control">
                    <%= ff.label :host, 'Host Address', class: 'label' %>
                    <%= ff.text_field :host, value: value['host'], required: true, class: 'base-input', placeholder: t('smtp_placeholder_host', default: 'smtp.example.com') %>
                  </div>
                  <div class="form-control">
                    <%= ff.label :port, 'Port', class: 'label' %>
                    <%= ff.text_field :port, value: value['port'], required: true, class: 'base-input', placeholder: t('smtp_placeholder_port', default: '587') %>
                  </div>
                </div>
              </div>

              <div class="smtp-field-group-divider" aria-hidden="true"></div>

              <div class="smtp-field-group">
                <p class="smtp-field-group-label" id="smtp-group-mailbox">
                  <%= t('smtp_subgroup_mailbox', default: 'Mailbox authentication') %>
                </p>
                <div class="grid gap-6 md:grid-cols-2">
                  <div class="form-control">
                    <%= ff.label :username, 'Username (Email)', class: 'label' %>
                    <%= ff.text_field :username, value: value['username'], class: 'base-input', placeholder: t('smtp_placeholder_username', default: 'notifications@company.com') %>
                  </div>
                  <div class="form-control">
                    <%= ff.label :password, 'Password', class: 'label' %>
                    <%= ff.password_field :password,
                      class: 'base-input',
                      required: value['password'].present?,
                      placeholder: value['password'].present? ? t('smtp_placeholder_password_saved', default: 'Leave blank to keep existing password') : t('smtp_placeholder_password', default: '••••••••••••'),
                      autocomplete: 'new-password' %>
                  </div>
                </div>
              </div>
            </section>

            <section class="settings-card profile-settings-card profile-settings-card--smtp-identity">
              <div class="settings-card-header">
                <div>
                  <h2 class="settings-card-title flex items-center gap-2.5">
                    <%= svg_icon('info_circle', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
                    <span><%= t('identity_routing', default: 'Identity & Routing') %></span>
                  </h2>
                  <p class="settings-card-subtitle">
                    <%= t('smtp_identity_routing_hint', default: 'How Docuseal authenticates and what address recipients see as the sender.') %>
                  </p>
                </div>
              </div>
              <div class="grid gap-6 md:grid-cols-2">
                <div class="form-control">
                  <%= ff.label :domain, "Domain (#{t('optional')})", class: 'label' %>
                  <%= ff.text_field :domain,
                    value: value['domain'],
                    class: 'base-input',
                    placeholder: t('smtp_placeholder_domain', default: 'mail.example.com') %>
                </div>
                <div class="form-control">
                  <%= ff.label :authentication, 'Authentication', class: 'label' %>
                  <%= ff.select :authentication,
                    options_for_select([%w[Plain plain], %w[Login login], %w[CRAM-MD5 cram_md5]], value.fetch('authentication', 'plain')),
                    { prompt: t('smtp_prompt_authentication', default: 'Select authentication') },
                    { required: true, class: 'base-select' } %>
                </div>
              </div>

              <div class="smtp-from-highlight mt-8">
                <%= ff.label :from_email, t('send_from_email'), class: 'smtp-from-highlight-label' %>
                <p class="smtp-from-highlight-hint" id="smtp-from-email-hint">
                  <%= t('smtp_from_email_microcopy', default: 'Shown as the sender on notifications and completion emails. Use an address your domain is allowed to send from.') %>
                </p>
                <%= ff.email_field :from_email,
                  value: value['from_email'],
                  required: !Docuseal.multitenant?,
                  class: 'base-input smtp-from-input',
                  placeholder: t('smtp_placeholder_from', default: 'no-reply@company.com'),
                  aria: { describedby: 'smtp-from-email-hint' } %>
              </div>
            </section>
          </div>

          <aside class="settings-profile-secondary profile-settings-column profile-settings-column--secondary">
            <% if !Docuseal.multitenant? || can?(:manage, :personalization_advanced) %>
              <section class="settings-card profile-settings-card profile-settings-card--smtp-security">
                <div class="settings-card-header">
                  <div>
                    <h2 id="smtp-security-heading" class="settings-card-title flex items-center gap-2.5">
                      <%= svg_icon('lock', class: 'profile-settings-card-icon shrink-0 w-5 h-5') %>
                      <span><%= t('smtp_security', default: 'SMTP Security') %></span>
                    </h2>
                    <p class="settings-card-subtitle">
                      <%= t('smtp_security_hint', default: 'Choose how the connection to your mail server is encrypted.') %>
                    </p>
                  </div>
                </div>
                <div
                  class="smtp-security-card space-y-3"
                  role="radiogroup"
                  aria-labelledby="smtp-security-heading"
                >
                  <% [
                    ['none', 'STARTTLS', t('opportunistic_encryption', default: 'Opportunistic encryption')],
                    ['tls', 'TLS', t('transport_layer_security', default: 'Transport Layer Security')],
                    ['ssl', 'SSL', t('legacy_encryption', default: 'Legacy encryption')],
                    ['noverify', 'Noverify', t('ignore_certificate_warnings', default: 'Ignore certificate warnings')]
                  ].each do |(val, label, description)| %>
                    <div class="smtp-security-option">
                      <%= ff.radio_button :security, val, checked: (value['security'].blank? && val == 'none') || value['security'] == val, id: "#{val}_radio", class: 'smtp-security-radio' %>
                      <label for="<%= "#{val}_radio" %>" class="smtp-security-option-copy">
                        <p class="smtp-security-option-title"><%= label %></p>
                        <p class="smtp-security-option-description"><%= description %></p>
                      </label>
                    </div>
                  <% end %>
                </div>
              </section>
            <% end %>

            <section class="settings-card profile-settings-card profile-settings-card--smtp-actions">
              <p class="smtp-save-hint">
                <%= t('smtp_save_hint', default: 'Saved settings apply to the next emails sent from this workspace.') %>
              </p>
              <div class="settings-card-actions profile-settings-card-actions smtp-save-actions">
                <%= f.button button_title(
                      title: t('save_configuration', default: t('save')),
                      disabled_with: t('saving'),
                      icon: svg_icon('save', class: 'w-4 h-4')
                    ),
                    class: 'base-button profile-settings-btn-primary w-full flex items-center justify-center gap-2' %>
              </div>
            </section>
          </aside>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
