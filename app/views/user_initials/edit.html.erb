<%= render 'shared/turbo_modal',
  title: t('update_initials'),
  signature_editor: true,
  unsaved_close_prompt: t('initials_modal_unsaved_close', default: 'You have unsaved initials. Close without saving?') do %>
  <% options = [[t('draw'), 'draw'], [t('upload'), 'upload']] %>
  <div class="signature-editor">
    <p class="signature-editor__lead" id="initials-modal-description">
      <%= t('initials_editor_intro', default: 'Draw your initials with your pointer or stylus, or upload a PNG or JPG image.') %>
    </p>

    <toggle-visible data-element-ids="<%= options.map(&:last).to_json %>" class="signature-editor__toggle block w-full">
      <div class="signature-editor__segmented" role="radiogroup" aria-label="<%= t('initials_editor_mode_label', default: 'How to add your initials') %>">
        <% options.each do |(label, value)| %>
          <span class="signature-editor__segment-wrap">
            <%= radio_button_tag 'option',
              value,
              value == 'draw',
              class: 'peer hidden signature-editor__segment-input',
              data: { action: 'change:toggle-visible#trigger' },
              id: "initials_option_#{value}" %>
            <label for="initials_option_<%= value %>" class="signature-editor__segment">
              <% if value == 'draw' %>
                <%= svg_icon('pencil', class: 'signature-editor__segment-icon') %>
              <% else %>
                <%= svg_icon('cloud_upload', class: 'signature-editor__segment-icon') %>
              <% end %>
              <span class="signature-editor__segment-text"><%= label %></span>
            </label>
          </span>
        <% end %>
      </div>
    </toggle-visible>

    <div id="draw" class="signature-editor__panel signature-editor__panel--draw" aria-labelledby="initials-draw-heading" role="region">
      <%= form_for @user_config, url: user_initials_path, method: :put, data: { turbo_frame: :_top }, html: { autocomplete: :off, enctype: 'multipart/form-data', class: 'signature-editor__draw-form' } do |f| %>
        <signature-form class="signature-editor__form block w-full">
          <h3 id="initials-draw-heading" class="signature-editor__section-label sr-only"><%= t('initials_editor_draw_section', default: 'Draw initials') %></h3>
          <div class="signature-editor__canvas-card">
            <div class="signature-editor__canvas-toolbar">
              <span class="signature-editor__canvas-label">
                <%= svg_icon('pencil', class: 'signature-editor__canvas-label-ico') %>
                <%= t('initials_editor_draw_below', default: 'Draw your initials below') %>
              </span>
              <a class="signature-editor__clear link" data-target="signature-form.clear" href="#" role="button">
                <%= svg_icon('trash', class: 'signature-editor__clear-ico') %>
                <%= t('clear') %>
              </a>
            </div>
            <div class="signature-editor__canvas-frame">
              <canvas data-target="signature-form.canvas" class="signature-editor__canvas-surface w-full rounded-lg" aria-label="<%= t('initials_editor_canvas_label', default: 'Initials drawing area') %>"></canvas>
            </div>
            <input name="file" class="hidden" data-target="signature-form.input" type="file" accept="image/png,image/jpeg,image/jpg">
          </div>
          <div class="signature-editor__actions">
            <button type="button" class="signature-editor__cancel btn btn-ghost" data-turbo-modal-close>
              <%= t('cancel', default: 'Cancel') %>
            </button>
            <%= f.button button_title(title: t('save'), disabled_with: t('saving')),
              class: 'base-button signature-editor__save',
              data: { target: 'signature-form.button' },
              disabled: true,
              aria: { describedby: 'initials-modal-description' } %>
          </div>
        </signature-form>
      <% end %>
    </div>

    <div id="upload" class="signature-editor__panel signature-editor__panel--upload hidden" role="region" aria-labelledby="initials-upload-heading">
      <%= form_for @user_config, url: user_initials_path, method: :put, data: { turbo_frame: :_top }, html: { autocomplete: :off, enctype: 'multipart/form-data', class: 'signature-editor__upload-form' } do |f| %>
        <h3 id="initials-upload-heading" class="signature-editor__section-label sr-only"><%= t('initials_editor_upload_section', default: 'Upload initials') %></h3>
        <file-dropzone data-submit-on-upload="true" class="signature-editor__dropzone-root w-full block">
          <label for="initials_file_upload" class="signature-editor__dropzone">
            <div class="signature-editor__dropzone-inner">
              <span class="signature-editor__dropzone-icon-wrap" data-target="file-dropzone.icon">
                <%= svg_icon('cloud_upload', class: 'signature-editor__dropzone-icon') %>
              </span>
              <span data-target="file-dropzone.loading" class="hidden signature-editor__dropzone-loading">
                <%= svg_icon('loader', class: 'signature-editor__dropzone-loader animate-spin') %>
              </span>
              <span class="signature-editor__dropzone-title"><%= t('upload_initials') %></span>
              <span class="signature-editor__dropzone-hint"><%= t('click_to_upload_or_drag_and_drop_html') %></span>
              <span class="signature-editor__formats"><%= t('initials_editor_formats_hint', default: 'PNG or JPG · max quality recommended') %></span>
            </div>
            <input id="initials_file_upload" name="file" class="hidden" data-action="change:file-dropzone#onSelectFiles" data-target="file-dropzone.input" type="file" accept="image/png,image/jpeg,image/jpg">
          </label>
        </file-dropzone>
        <div class="signature-editor__actions">
          <button type="button" class="signature-editor__cancel btn btn-ghost" data-turbo-modal-close>
            <%= t('cancel', default: 'Cancel') %>
          </button>
          <%= f.button button_title(title: t('save'), disabled_with: t('saving')),
            class: 'base-button signature-editor__save signature-editor__save--upload' %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
