<!DOCTYPE html>
<% initial_theme = cookies['cybros-theme'] == 'docuseal-light' ? 'docuseal-light' : 'docuseal-dark' %>
<html data-theme="<%= initial_theme %>" lang="<%= I18n.locale %>">
  <head>
    <%= render 'layouts/head_tags' %>
    <% if Docuseal.enable_pwa? %>
      <link rel="manifest" href="/manifest.json">
    <% end %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <%= csrf_meta_tags %>
    <% if ENV['ROLLBAR_CLIENT_TOKEN'] %>
      <meta name="rollbar-token" content="<%= ENV.fetch('ROLLBAR_CLIENT_TOKEN', nil) %>">
      <%= javascript_pack_tag 'rollbar', 'application', defer: true %>
    <% else %>
      <%= javascript_pack_tag 'application', defer: true %>
    <% end %>
    <% if canonical_url = content_for(:canonical_url) %>
      <link href="<%= canonical_url %>" rel="canonical">
    <% end %>
    <%= stylesheet_pack_tag 'application', media: 'all' %>
  </head>
  <body class="min-h-screen bg-base-100<%= ' docuseal-landing' if @marketing_landing %>" data-revalidate-on-back="<%= signed_in? %>">
    <% if params[:modal].present? %>
      <% url_params = Rails.application.routes.recognize_path(params[:modal], method: :get) %>
      <% if url_params[:action] == 'new' %>
        <open-modal src="<%= url_for(url_params) %>"></open-modal>
      <% end %>
    <% end %>
    <turbo-frame id="modal"></turbo-frame>
    <turbo-frame id="drawer"></turbo-frame>
    <% if signed_in? %>
      <div class="drawer lg:drawer-open min-h-screen">
        <input id="app-sidebar-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content flex min-h-screen min-w-0 flex-col">
          <%= render 'shared/navbar' %>
          <% if flash.present? %><%= render 'shared/flash' %><% end %>
          <% signed_page_class = request.path.start_with?('/settings') ? 'page-stack' : 'page-stack' %>
          <main class="ds-page-shell flex-1 min-w-0">
            <div class="<%= signed_page_class %>">
              <%= yield %>
            </div>
          </main>
        </div>
        <div class="drawer-side z-[35] border-0 bg-transparent p-0 lg:border-e lg:border-white/[0.06]">
          <label for="app-sidebar-drawer" aria-label="<%= t('close_menu', default: 'Close menu') %>" class="drawer-overlay app-sidebar-drawer-overlay lg:hidden"></label>
          <%= render 'shared/app_sidebar' %>
        </div>
      </div>
    <% else %>
      <% unless @marketing_landing %>
        <%= render 'shared/navbar' %>
      <% end %>
      <% if flash.present? %><%= render 'shared/flash' %><% end %>
      <main class="page-shell page-stack">
        <%= yield %>
      </main>
    <% end %>
    <%= render 'shared/body_scripts' %>
  </body>
</html>
