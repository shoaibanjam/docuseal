<%= form_for '', url: submit_form_decline_index_path(submitter.slug), method: :post do |f| %>
  <div class="tpl-new-form">
    <p class="signature-editor__lead">
      <%= t(:notify_the_sender_with_the_reason_you_declined) %>
    </p>
    <div class="form-control mt-4">
      <%= f.label :reason, t('provide_a_reason'), class: 'label' %>
      <%= f.text_area :reason, required: true, class: 'base-input w-full py-2', dir: 'auto', placeholder: t('provide_a_reason'), style: 'height: 200px', rows: '10' %>
    </div>
    <div class="form-control mt-1">
      <%= f.button button_title(title: t(:decline)), class: 'base-button tpl-new-submit-btn' %>
    </div>
  </div>
<% end %>
