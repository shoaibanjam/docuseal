<% get_started_path = Docuseal.multitenant? ? sign_up_path : new_user_registration_path %>
<% login_path = new_user_session_path %>

<div class="profile-settings-page landing-page-shell">
  <main class="landing-page landing-page--cloud landing-page--refined">
    <a href="#landing-hero" class="landing-skip-link sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:inline-flex focus:px-4 focus:py-2.5 focus:text-sm focus:font-semibold focus:shadow-lg focus:outline-none"><%= t('skip_to_main_content', default: 'Skip to main content') %></a>
  <%= render 'pages/landing/nav', get_started_path: get_started_path, login_path: login_path %>
  <%= render 'pages/landing/hero', get_started_path: get_started_path %>
  <%= render 'pages/landing/social_proof' %>
  <%= render 'pages/landing/advanced_template_builder' %>
  <%= render 'pages/landing/features_grid' %>
  <%= render 'pages/landing/solutions_grid' %>
  <%= render 'pages/landing/workflow_automated' %>
  <%= render 'pages/landing/modern_workflows_features' %>
  <%= render 'pages/landing/fields_grid', login_path: login_path %>
  <%= render 'pages/landing/multi_party_collaboration' %>
  <%= render 'pages/landing/security' %>
  <%= render 'pages/landing/enterprise_grade_security' %>
  <%= render 'pages/landing/faq' %>
  <%= render 'pages/landing/final_cta', get_started_path: get_started_path, login_path: login_path %>
  <%= render 'pages/landing/footer', login_path: login_path %>
  </main>
</div>

<div class="landing-section landing-attribution">
  <%= render 'shared/attribution', with_counter: true %>
</div>
