<header class="landing-nav sticky top-0 z-[60] border-b border-white/10 supports-[backdrop-filter]:bg-[#050a14]/75 supports-[backdrop-filter]:backdrop-blur-xl bg-[#050a14]/92">
  <div class="relative z-[1] mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-3.5 md:gap-8">
    <%= link_to root_path, class: 'landing-nav-brand-link flex shrink-0 items-center text-white transition-opacity hover:opacity-90', aria: { label: Docuseal.product_name } do %>
      <%= render 'shared/logo', class: 'h-9 w-auto object-contain shrink-0' %>
    <% end %>
    <nav class="hidden flex-1 items-center justify-center gap-8 md:flex" aria-label="Primary">
      <a href="#landing-products" class="landing-nav-link text-sm font-medium text-slate-400 transition-colors duration-200 hover:text-emerald-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400/60 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14] rounded-sm">Products</a>
      <a href="#landing-solutions" class="landing-nav-link text-sm font-medium text-slate-400 transition-colors duration-200 hover:text-emerald-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400/60 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14] rounded-sm">Solutions</a>
      <a href="#landing-faq" class="landing-nav-link text-sm font-medium text-slate-400 transition-colors duration-200 hover:text-emerald-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400/60 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14] rounded-sm">Company</a>
    </nav>
    <div class="flex shrink-0 items-center gap-2 md:gap-3">
      <div class="dropdown dropdown-end md:hidden">
        <div tabindex="0" role="button" class="btn btn-ghost btn-square min-h-10 min-w-10 border border-white/15 text-white hover:border-emerald-400/40 hover:bg-white/5" aria-label="<%= t('open_menu', default: 'Open menu') %>">
          <span class="material-symbols-outlined text-[22px] leading-none" aria-hidden="true">menu</span>
        </div>
        <ul tabindex="0" class="dropdown-content landing-mobile-nav-menu menu z-[70] mt-2 w-56 rounded-xl border border-white/10 bg-[#0d1c2f]/98 p-2 shadow-2xl shadow-black/40 backdrop-blur-md">
          <li><a href="#landing-products" class="rounded-lg text-slate-200 hover:bg-white/10 hover:text-emerald-300"><%= t('landing.nav.products', default: 'Products') %></a></li>
          <li><a href="#landing-solutions" class="rounded-lg text-slate-200 hover:bg-white/10 hover:text-emerald-300"><%= t('landing.nav.solutions', default: 'Solutions') %></a></li>
          <li><a href="#landing-faq" class="rounded-lg text-slate-200 hover:bg-white/10 hover:text-emerald-300"><%= t('landing.nav.company', default: 'Company') %></a></li>
          <li><a href="#landing-security" class="rounded-lg text-slate-200 hover:bg-white/10 hover:text-emerald-300"><%= t('landing.nav.security', default: 'Security') %></a></li>
        </ul>
      </div>
      <theme-toggle class="landing-nav-theme inline-flex items-center justify-center">
        <button type="button" class="theme-toggle-btn" aria-label="Toggle color theme" title="Toggle color theme">
          <span data-theme-icon="sun">
            <%= svg_icon('sun', class: 'w-5 h-5') %>
          </span>
          <span data-theme-icon="moon" class="hidden">
            <%= svg_icon('moon', class: 'w-5 h-5') %>
          </span>
        </button>
      </theme-toggle>
      <% if request.path != new_user_session_path && request.path != setup_index_path %>
        <%= link_to login_path, class: 'landing-nav-login inline-flex items-center gap-1.5 rounded-lg px-2 py-2 text-sm font-medium text-white/90 transition hover:text-white md:px-3' do %>
          <%= svg_icon('login', class: 'h-5 w-5 shrink-0') %>
          <span class="hidden sm:inline"><%= t('sign_in') %></span>
        <% end %>
      <% end %>
      <%= link_to 'Get Started', get_started_path, class: 'landing-nav-cta inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-semibold shadow-lg transition duration-200 hover:scale-[1.02] active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14] md:px-5' %>
    </div>
  </div>
</header>
