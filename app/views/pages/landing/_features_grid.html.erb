<section id="landing-products" class="landing-section landing-features-grid py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
      <span class="landing-cloud-badge mx-auto mb-4 inline-block">Core features</span>
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        Built for teams that need <span class="landing-gradient-text">signing that ships fast</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Everything in one place to prepare templates, collect signatures, and integrate with your existing systems.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% products = [
        { icon: 'domain', title: 'Template builder', copy: 'Create fillable templates from PDF or DOCX and place fields where signers need to complete them.' },
        { icon: 'draw', title: 'Online signing', copy: 'Collect legally recognized e-signatures with signer flows that work across desktop and mobile.' },
        { icon: 'api', title: 'API and webhooks', copy: 'Create templates and submissions programmatically, then react to events in your backend.' },
        { icon: 'groups', title: 'Multi-recipient flows', copy: 'Send to one or many recipients with role-based completion and shared progress tracking.' },
        { icon: 'mail', title: 'Email delivery', copy: 'Send signing requests and reminders through SMTP-based email notifications.' },
        { icon: 'verified', title: 'PDF verification', copy: 'Verify digital signatures and exported signed documents directly from the platform.' }
      ] %>
      <% products.each_with_index do |p, idx| %>
        <article class="landing-products-card landing-refined-card landing-surface-interactive landing-tilt group flex flex-col rounded-2xl p-8 transition duration-300" data-aos="fade-up" data-aos-delay="<%= [idx * 75, 375].min %>">
          <div class="landing-card-icon mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl">
            <span class="material-symbols-outlined text-[26px]" style="font-variation-settings: 'FILL' 0, 'wght' 400;"><%= p[:icon] %></span>
          </div>
          <h3 class="text-xl font-semibold text-white"><%= p[:title] %></h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400"><%= p[:copy] %></p>
          <a href="#landing-solutions" class="landing-products-link mt-6 inline-flex items-center gap-1 text-sm font-semibold transition group-hover:gap-2">
            Learn more
            <span aria-hidden="true">→</span>
          </a>
        </article>
      <% end %>
    </div>
  </div>
</section>
