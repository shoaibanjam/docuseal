<section id="landing-products" class="landing-section landing-features-grid py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="landing-cloud-badge mx-auto mb-4 inline-block">Our products</span>
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        Best‑in‑class tools, <span class="landing-gradient-text">fully managed for you</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Everything you need to design, send, sign, and archive documents at scale—without sacrificing compliance or developer experience.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      <% products = [
        { icon: 'domain', title: 'Template studio', copy: 'Drag‑and‑drop builder with conditional logic, roles, and reusable layouts for every agreement type.' },
        { icon: 'draw', title: 'Secure signing', copy: 'Legally robust e‑signatures with audit trails, identity options, and mobile‑first completion flows.' },
        { icon: 'api', title: 'Developer API', copy: 'REST endpoints, webhooks, and embeds that slot into your CI/CD and product surface area.' },
        { icon: 'gavel', title: 'Compliance hub', copy: 'Retention policies, exports, and evidence packs designed for legal and procurement reviews.' },
        { icon: 'rocket_launch', title: 'Global delivery', copy: 'Localized emails, multi‑language flows, and resilient infrastructure wherever your signers are.' },
        { icon: 'bar_chart', title: 'Analytics', copy: 'Funnel visibility from draft to signed so revenue and operations teams stay aligned.' }
      ] %>
      <% products.each do |p| %>
        <article class="landing-products-card group flex flex-col rounded-2xl border border-white/10 bg-[#0a1220] p-8 transition hover:border-sky-500/30 hover:shadow-xl hover:shadow-sky-500/10">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-sky-500/25 to-violet-500/20 text-sky-200">
            <span class="material-symbols-outlined text-[26px]" style="font-variation-settings: 'FILL' 0, 'wght' 400;"><%= p[:icon] %></span>
          </div>
          <h3 class="text-xl font-semibold text-white"><%= p[:title] %></h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400"><%= p[:copy] %></p>
          <a href="#landing-solutions" class="landing-products-link mt-6 inline-flex items-center gap-1 text-sm font-semibold text-sky-400 transition group-hover:gap-2">
            Learn more
            <span aria-hidden="true">→</span>
          </a>
        </article>
      <% end %>
    </div>
  </div>
</section>
