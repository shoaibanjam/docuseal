<section id="landing-security" class="landing-section landing-security bg-[#fdf8f5] py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white p-10 shadow-sm md:p-14">
      <div class="pointer-events-none absolute right-6 top-5">
        <img src="/landing/security-watermark.png" alt="" class="landing-security-watermark h-28 w-28 object-contain" loading="lazy">
      </div>

      <div class="relative z-10 max-w-4xl">
        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-emerald-600">Trust & Compliance</span>
        <h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Global Standards of Security</h2>
        <p class="mt-4 text-lg text-slate-500">
          Security is our foundation. We maintain rigorous certifications and operational controls to keep your
          agreements private, compliant, and protected.
        </p>

        <div class="mt-8 grid grid-cols-2 items-center gap-4 opacity-75 md:grid-cols-4">
          <% ['SOC 2', 'HIPAA', 'GDPR', 'ISO 27001'].each do |item| %>
            <div class="border-r border-slate-200 py-2 text-center text-xl font-bold text-slate-700 last:border-r-0 md:text-2xl"><%= item %></div>
          <% end %>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <div class="flex gap-3">
            <span class="landing-security-item-icon mt-0.5 inline-flex items-center justify-center text-emerald-600">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
              </svg>
            </span>
            <div>
              <h3 class="text-base font-semibold text-slate-900">AES-256 Encryption</h3>
              <p class="mt-1 text-sm text-slate-500">Data is encrypted in transit and at rest with enterprise-grade cryptographic protocols.</p>
            </div>
          </div>
          <div class="flex gap-3">
            <span class="landing-security-item-icon mt-0.5 inline-flex items-center justify-center text-emerald-600">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M9 4v1.38c-.83-.33-1.72-.5-2.61-.5-1.79 0-3.58.68-4.95 2.05l3.33 3.33h1.11v1.11c.86.86 1.98 1.31 3.11 1.36V15H6v3c0 1.1.9 2 2 2h10c1.66 0 3-1.34 3-3V4H9zm-1.11 6.41V8.26H5.61L4.57 7.22a5.07 5.07 0 0 1 1.82-.34c1.34 0 2.59.52 3.54 1.46l1.41 1.41-.2.2a2.7 2.7 0 0 1-1.92.8c-.47 0-.93-.12-1.33-.34zM19 17c0 .55-.45 1-1 1s-1-.45-1-1v-2h-6v-2.59c.57-.23 1.1-.57 1.56-1.03l.2-.2L15.59 14H17v-1.41l-6-5.97V6h8v11z"/>
              </svg>
            </span>
            <div>
              <h3 class="text-base font-semibold text-slate-900">Full Audit Trails</h3>
              <p class="mt-1 text-sm text-slate-500">Every action is recorded with time, IP, and event metadata for complete traceability.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
