<section id="landing-solutions" class="landing-section landing-solutions-grid py-24 md:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-aos="fade-up">
      <span class="landing-cloud-badge mx-auto mb-4 inline-block">Why teams choose it</span>
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-4xl">
        One platform. Practical workflows. <span class="landing-gradient-text">No lock-in.</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        From template design to signed output, <%= Docuseal.product_name %> covers the complete signing flow in a single app.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% solutions = [
        { icon: 'bolt', title: 'Self-host or cloud', copy: 'Deploy with Docker and keep your documents under your own operational control.' },
        { icon: 'hub', title: 'API-first platform', copy: 'Use REST endpoints and webhooks to connect document flows to your product.' },
        { icon: 'devices', title: 'Mobile-friendly signing', copy: 'Signers can complete documents from desktop and mobile browsers.' },
        { icon: 'shield', title: 'Auditability built in', copy: 'Track signer and submission events with downloadable signed documents.' },
        { icon: 'group', title: 'Team management', copy: 'Manage users, roles, templates, and submissions from a shared workspace.' },
        { icon: 'extension', title: 'Integrations', copy: 'Use webhooks, SMTP, and storage integrations to fit existing infrastructure.' }
      ] %>
      <% solutions.each_with_index do |item, idx| %>
        <div class="landing-solutions-card landing-refined-card landing-surface-interactive landing-tilt rounded-2xl p-6 transition duration-300" data-aos="zoom-in" data-aos-delay="<%= [idx * 60, 300].min %>" data-aos-duration="600">
          <div class="landing-card-icon mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl">
            <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1, 'wght' 500;"><%= item[:icon] %></span>
          </div>
          <h3 class="text-lg font-semibold text-white"><%= item[:title] %></h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400"><%= item[:copy] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
