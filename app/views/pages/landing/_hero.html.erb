<section class="landing-section landing-hero relative overflow-hidden bg-[#050a14] pb-16 pt-0 md:pb-24">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-0 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(56,189,248,0.22),transparent_68%)]"></div>
    <div class="absolute bottom-0 right-0 h-[380px] w-[380px] translate-x-1/4 translate-y-1/4 rounded-full bg-[radial-gradient(circle,rgba(167,139,250,0.18),transparent_70%)]"></div>
    <div class="absolute left-0 top-1/3 h-[280px] w-[280px] -translate-x-1/3 rounded-full bg-[radial-gradient(circle,rgba(14,165,233,0.12),transparent_65%)]"></div>
  </div>

  <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-12 px-6 pt-3 md:pt-6 lg:flex-row lg:items-center lg:gap-16">
    <div class="w-full text-center lg:w-1/2 lg:text-left">
      <span class="landing-cloud-badge mb-6 inline-flex">Next‑gen document infrastructure</span>
      <h1 class="landing-hero-title text-4xl font-bold leading-[1.1] tracking-tight text-white md:text-5xl lg:text-6xl">
        <span class="landing-gradient-text"><%= Docuseal.product_name %></span>
        powering the future of
        <span class="landing-gradient-text">secure</span>
        business workflows
      </h1>
      <p class="landing-hero-copy mx-auto mt-6 max-w-xl text-lg leading-relaxed text-slate-400 lg:mx-0">
        The flexible e‑signature and document platform for teams that need airtight security, deep API control, and beautiful signing experiences.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
        <%= link_to 'Start building now', get_started_path, class: 'landing-btn-gradient inline-flex min-h-[52px] items-center justify-center rounded-full px-8 py-3.5 text-base font-semibold text-[#050a14] shadow-lg shadow-sky-500/25 transition hover:brightness-105' %>
        <a href="#landing-security" class="landing-hero-secondary inline-flex min-h-[52px] items-center justify-center rounded-full border-2 border-white/35 px-8 py-3.5 text-base font-semibold text-white transition hover:bg-white/10">
          View security
        </a>
      </div>
    </div>

    <div class="w-full lg:w-1/2">
      <div class="landing-hero-media relative mx-auto max-w-xl overflow-hidden rounded-2xl border border-white/10 bg-[#0a1220]/80 shadow-2xl shadow-black/40 backdrop-blur-sm lg:mx-0 lg:max-w-none">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQdDB4qUgr63aEJrmPO0mWkaKv7yI5yctaXXIgNqQz5HJQflVUMNr16-Wo3TwgUDS2uL62YlVIyEOV2_V48yvn4eJjhVcvNiUP2j7dU7esxEaiusHeC0rYQacvKXQ4VcEjrI5Cehqo6GlTLlMkJD-yQ51VvbFFBLuAVlUhru1TAP__KrjUwHLTox76_CgmlkYUnp6hrBlxy9ple7bhiL_XyVJXuW2M2yXp6_pkXWCwTD9F_bSDSy7auQb5bXjaaV2HSnjgHdmTPRr2"
          alt="Enterprise dashboard interface"
          class="landing-hero-dashboard-image h-auto w-full"
          loading="lazy"
        >
        <div class="landing-hero-media-overlay pointer-events-none absolute inset-0 bg-gradient-to-t from-[#050a14]/55 via-transparent to-transparent"></div>
      </div>
    </div>
  </div>
</section>
