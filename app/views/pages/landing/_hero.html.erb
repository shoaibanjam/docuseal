<section id="landing-hero" class="landing-section landing-hero relative overflow-hidden pb-16 pt-0 md:pb-24">
  <div class="pointer-events-none absolute inset-0 landing-hero-aurora" aria-hidden="true">
    <div class="landing-hero-orb landing-hero-orb--a absolute left-1/2 top-0 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(4,190,153,0.2),transparent_68%)]"></div>
    <div class="landing-hero-orb landing-hero-orb--b absolute bottom-0 right-0 h-[380px] w-[380px] translate-x-1/4 translate-y-1/4 rounded-full bg-[radial-gradient(circle,rgba(38,203,176,0.16),transparent_70%)]"></div>
    <div class="landing-hero-orb landing-hero-orb--c absolute left-0 top-1/3 h-[280px] w-[280px] -translate-x-1/3 rounded-full bg-[radial-gradient(circle,rgba(128,224,206,0.12),transparent_65%)]"></div>
  </div>

  <div class="relative mx-auto flex max-w-7xl flex-col items-center gap-12 px-6 pt-3 md:pt-6 lg:flex-row lg:items-center lg:gap-16">
    <div class="w-full text-center lg:w-1/2 lg:text-left" data-aos="fade-right" data-aos-duration="750">
      <span class="landing-cloud-badge mb-6 inline-flex motion-safe:animate-[landing-badge-pop_0.6s_ease-out_both]">Next‑gen document infrastructure</span>
      <h1 class="landing-hero-title text-4xl font-bold leading-[1.1] tracking-tight text-white md:text-5xl lg:text-6xl">
        <span class="sr-only">
          <%= Docuseal.product_name %>
          <%= t('landing.hero.headline_sr', default: 'powers the future of secure, compliant, scalable, automated, and trusted business workflows') %>
        </span>
        <span aria-hidden="true">
          <span class="landing-gradient-text"><%= Docuseal.product_name %></span>
          powering the future of
          <%= tag.span(
                '',
                id: 'landing-hero-typed',
                class: 'landing-gradient-text landing-hero-typed inline-block min-h-[1.15em] align-baseline',
                data: {
                  landing_typed_strings: %w[secure compliant scalable automated trusted]
                }
              ) %>
          business workflows
        </span>
      </h1>
      <p class="landing-hero-copy mx-auto mt-6 max-w-xl text-lg leading-relaxed text-slate-400 lg:mx-0">
        The flexible e‑signature and document platform for teams that need airtight security, deep API control, and beautiful signing experiences.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 lg:justify-start">
        <%= link_to 'Start building now', get_started_path, class: 'base-button profile-settings-btn-primary landing-hero-cta' %>
        <a href="#landing-security" class="tpl-show-action-btn tpl-show-action-btn--outline landing-hero-secondary-cta">
          View security
        </a>
      </div>
    </div>

    <div class="w-full lg:w-1/2" data-aos="fade-left" data-aos-duration="750" data-aos-delay="100">
      <div class="landing-hero-media landing-hero-media-lift landing-refined-panel relative mx-auto max-w-xl overflow-hidden rounded-2xl lg:mx-0 lg:max-w-none">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuBQdDB4qUgr63aEJrmPO0mWkaKv7yI5yctaXXIgNqQz5HJQflVUMNr16-Wo3TwgUDS2uL62YlVIyEOV2_V48yvn4eJjhVcvNiUP2j7dU7esxEaiusHeC0rYQacvKXQ4VcEjrI5Cehqo6GlTLlMkJD-yQ51VvbFFBLuAVlUhru1TAP__KrjUwHLTox76_CgmlkYUnp6hrBlxy9ple7bhiL_XyVJXuW2M2yXp6_pkXWCwTD9F_bSDSy7auQb5bXjaaV2HSnjgHdmTPRr2"
          alt="Enterprise dashboard interface"
          class="landing-hero-dashboard-image landing-hero-dashboard-image--dark h-auto w-full"
          loading="lazy"
        >
        <img
          src="/landing/hero-light.png"
          alt="Landing page dashboard preview"
          class="landing-hero-dashboard-image landing-hero-dashboard-image--light h-auto w-full"
          loading="lazy"
        >
        <div class="landing-hero-media-overlay pointer-events-none absolute inset-0"></div>
      </div>
    </div>
  </div>
</section>
