      <div class="splide__track">
        <ul class="splide__list">
          <% trust_logos.each do |logo| %>
            <li class="splide__slide">
              <div class="flex h-full min-h-[2.5rem] items-center justify-center gap-2 px-4">
                <svg class="h-5 w-5 shrink-0 <%= logo[:icon] %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
                  <path d="<%= logo[:path] %>"/>
                </svg>
                <span class="whitespace-nowrap text-lg font-bold tracking-wide"><%= logo[:name] %></span>
              </div>
            </li>
