<section class="landing-section landing-final-cta relative overflow-hidden py-24 md:py-32">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_0%,rgba(4,190,153,0.16),transparent)]"></div>
  <div class="relative mx-auto max-w-7xl px-6 text-center">
    <div class="landing-final-cta-panel landing-tilt landing-surface-interactive mx-auto max-w-4xl rounded-[28px] border border-[#2A3F5F] bg-[#112240]/90 p-10 shadow-2xl shadow-black/30 backdrop-blur-md md:p-16" data-aos="zoom-in" data-aos-duration="750">
      <h2 class="text-3xl font-bold tracking-tight text-white md:text-5xl">
        Ready to <span class="landing-gradient-text">streamline</span> document signing?
      </h2>
      <p class="landing-final-cta-copy mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Start creating templates, sending signature requests, and integrating signing into your product.
      </p>
      <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row sm:flex-wrap">
        <%= link_to 'Get started for free', get_started_path, class: 'landing-btn-gradient landing-btn-primary-glow inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-[#07111f] shadow-lg shadow-emerald-500/25 transition duration-200 hover:brightness-105 hover:scale-[1.02] active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14]' %>
        <%= link_to 'Sign in', login_path, class: 'landing-final-cta-secondary inline-flex items-center justify-center rounded-full border-2 border-white/35 px-8 py-4 text-base font-semibold text-white transition duration-200 hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 focus-visible:ring-offset-[#050a14]' %>
      </div>
    </div>
  </div>
</section>
