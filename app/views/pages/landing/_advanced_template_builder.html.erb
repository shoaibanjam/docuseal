<section class="landing-section landing-advanced-template bg-white py-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-10">
      <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-emerald-600">Efficiency</span>
      <h2 class="atb-title text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Advanced Template Builder</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-12">
      <div class="atb-main-card flex flex-col justify-between rounded-xl border border-slate-200 bg-[#f8f3f0] p-8 md:col-span-7">
        <div>
          <h3 class="atb-main-heading text-2xl font-semibold text-slate-900">Dynamic File Support</h3>
          <p class="atb-main-copy mt-3 text-slate-500">
            Seamlessly upload and manage PDF, DOCX, and HTML templates while keeping formatting consistent across devices.
          </p>
          <ul class="atb-main-list mt-5 space-y-3 text-sm text-slate-700">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm4.59-12.42L10 14.17l-2.59-2.58L6 13l4 4 8-8z"/>
              </svg>
              <span>Auto-detection of form fields</span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm4.59-12.42L10 14.17l-2.59-2.58L6 13l4 4 8-8z"/>
              </svg>
              <span>Intelligent field mapping</span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm4.59-12.42L10 14.17l-2.59-2.58L6 13l4 4 8-8z"/>
              </svg>
              <span>Version control for templates</span>
            </li>
          </ul>
        </div>

        <div class="mt-8 overflow-hidden rounded-lg border border-slate-200">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDkTsB2orktRbjSNW6zvhdB6SqOMF9Kc-HVZ0rV-w-svK4FRkxlcQf8nfWMmXaqhx3imCyqknVKxyU4667NlERsqxDjp4fqYpVSH5CckmHj2oMa1n3pSrRDrXZ6td9BDPpfcswz0wm6fHb_07lFWGeatLT-q5RTHxK4E71BJJRDUt1McA-qHYLB_eHsa0z17WXCV-2U_7zxATdVmfMVaw2a7WvRKnHlJH0AIQ0pn0k3ut2_vRRtlxsjAuz63aNsDEqH8hhTCBMvaIpL"
            alt="Template builder editor interface"
            class="atb-preview-image h-64 w-full object-cover"
            loading="lazy"
          >
        </div>
      </div>

      <div class="space-y-6 md:col-span-5">
        <div class="atb-auto-card rounded-xl bg-[#0d1c2f] p-8 text-white">
          <%= svg_icon('sparkles', class: 'mb-4 h-10 w-10 text-emerald-300') %>
          <h3 class="atb-auto-heading text-2xl font-semibold">Auto-Detection</h3>
          <p class="mt-3 text-slate-300">
            Automatically identify signature lines and text inputs in existing documents to save setup time.
          </p>
        </div>

        <div class="atb-mapping-card rounded-xl border border-slate-200 bg-[#ece7e4] p-8">
          <svg class="atb-mapping-icon mb-4 h-10 w-10 text-slate-900" xmlns="http://www.w3.org/2000/svg" viewBox="0 -960 960 960" fill="currentColor" aria-hidden="true">
            <path d="M766-120q-41 0-71.5-24.5T656-204H443q-66 0-109.5-43.5T290-357q0-66 43.5-109.5T443-510h77q41 0 67-26t26-67q0-41-26-67t-67-26H304q-9 35-39 59.5T194-612q-48 0-81-33t-33-81q0-48 33-81t81-33q41 0 71 24.5t39 59.5h216q66 0 109.5 43.5T673-603q0 66-43.5 109.5T520-450h-77q-41 0-67 26t-26 67q0 41 26 67t67 26h213q9-35 39-59.5t71-24.5q48 0 81 33t33 81q0 48-33 81t-81 33ZM232.5-687.5Q248-703 248-726t-15.5-38.5Q217-780 194-780t-38.5 15.5Q140-749 140-726t15.5 38.5Q171-672 194-672t38.5-15.5Z"/>
          </svg>
          <h3 class="atb-mapping-heading text-2xl font-semibold text-slate-900">Field Mapping</h3>
          <p class="atb-mapping-copy mt-3 text-slate-600">
            Sync document fields directly with your CRM or database using metadata mapping.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
