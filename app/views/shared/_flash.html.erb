<div id="flash" class="fixed inset-x-0 top-3 z-30 animate-fade-in pointer-events-none">
  <div class="max-w-xl mx-auto">
    <div class="px-4 py-3.5 rounded-2xl bg-base-100 border border-base-300/80 shadow-soft-xl flex items-center justify-between mx-4 md:mx-0 pointer-events-auto backdrop-blur-sm">
      <div class="flex items-center space-x-3">
        <% if flash[:notice] %>
          <%= svg_icon('info_circle', class: 'stroke-info flex-none w-6 h-6') %>
        <% else %>
          <%= svg_icon('exclamation_circle', class: 'stroke-error flex-none w-6 h-6') %>
        <% end %>
        <div class="text-sm md:text-base leading-snug">
          <span><%= flash[:notice] || flash[:alert] %></span>
        </div>
      </div>
      <remove-on-event data-event-type="click" data-selector-id="flash" class="ml-3 text-xl leading-none text-base-content/50 hover:text-base-content cursor-pointer">
        &times;
      </remove-on-event>
    </div>
  </div>
</div>
