<%= render 'shared/navbar_warning' %>
<header class="main-navbar w-full border-b border-white/5 sticky top-0 z-20 backdrop-blur-xl transition-shadow duration-200">
  <div class="max-w-7xl mx-auto px-4 md:px-6 py-3.5 md:py-4 flex items-center justify-between">
    <div class="flex items-center space-x-8 text-primary-content">
      <a href="<%= root_path %>" class="navbar-brand-link text-2xl font-bold items-center flex space-x-2 text-primary-content">
        <%= render 'shared/title' %>
      </a>
      <% if signed_in? %>
        <nav class="hidden md:flex items-center space-x-6">
          <% dashboard_view = cookies[:dashboard_view] %>
          <% on_root_dashboard = request.path == root_path %>
          <% is_templates = request.path.start_with?('/templates') || request.path.start_with?('/folders') || (on_root_dashboard && dashboard_view != 'submissions') %>
          <% is_submissions = request.path.start_with?('/submissions') || (on_root_dashboard && dashboard_view == 'submissions') %>
          <% is_settings = request.path.start_with?('/settings') %>

          <form action="<%= root_path %>" method="get" class="inline">
            <toggle-cookies data-value="templates" data-key="dashboard_view">
              <button type="submit" class="<%= "navbar-main-link font-medium text-base transition-colors duration-200 #{is_templates ? 'navbar-main-link--active text-secondary' : 'text-primary-content/70 hover:text-secondary'}" %>">
                <%= t('templates') %>
              </button>
            </toggle-cookies>
          </form>

          <form action="<%= submissions_path %>" method="get" class="inline">
            <toggle-cookies data-value="submissions" data-key="dashboard_view">
              <button type="submit" class="<%= "navbar-main-link font-medium text-base transition-colors duration-200 #{is_submissions ? 'navbar-main-link--active text-secondary' : 'text-primary-content/70 hover:text-secondary'}" %>">
                <%= t('submissions') %>
              </button>
            </toggle-cookies>
          </form>

          <%= link_to settings_profile_index_path, class: "navbar-main-link font-medium text-base transition-colors duration-200 #{is_settings ? 'navbar-main-link--active text-secondary' : 'text-primary-content/70 hover:text-secondary'}" do %>
            <%= t('settings') %>
          <% end %>
        </nav>
      <% end %>
    </div>
    <% if signed_in? %>
      <div class="space-x-4 flex items-center">
        <theme-toggle class="inline-flex items-center justify-center">
          <button type="button" class="theme-toggle-btn" aria-label="Toggle color theme" title="Toggle color theme">
            <span data-theme-icon="sun">
              <%= svg_icon('sun', class: 'w-5 h-5') %>
            </span>
            <span data-theme-icon="moon" class="hidden">
              <%= svg_icon('moon', class: 'w-5 h-5') %>
            </span>
          </button>
        </theme-toggle>
        <% if Docuseal.demo? %>
          <a href="https://docuseal.com/sign_up" class="btn btn-neutral btn-sm btn-outline inline-flex items-center justify-center" style="height: 37px">
            <%= t('sign_up') %>
          </a>
          <span class="hidden sm:inline">
            <%= render 'shared/github_button' %>
          </span>
        <% else %>
          <div class="flex items-center justify-center space-x-4 mr-1">
            <%= render 'shared/navbar_buttons' %>
          </div>
        <% end %>
      <div class="dropdown dropdown-end">
        <label tabindex="0" class="navbar-profile-trigger cursor-pointer bg-neutral text-neutral-content rounded-full p-2 w-9 h-9 justify-center items-center flex font-semibold text-sm transition-all duration-200 hover:opacity-90 active:scale-95">
          <span class="text-sm align-text-top"><%= current_user.initials %></span>
        </label>
        <ul tabindex="0" class="navbar-account-menu z-10 dropdown-content p-1.5 mt-2 shadow-soft-lg menu bg-base-100 rounded-lg min-w-[180px] text-right border border-base-300 animate-fade-in-up">
          <li>
            <%= link_to settings_profile_index_path, class: 'flex items-center gap-2' do %>
              <%= svg_icon('adjustments', class: 'w-5 h-5 flex-shrink-0 stroke-2 text-primary-content') %>
              <span class="whitespace-nowrap"><%= t('profile') %></span>
            <% end %>
          </li>
          <% if can?(:read, EncryptedConfig.new(key: EncryptedConfig::ESIGN_CERTS_KEY, account: current_account)) %>
            <li>
              <%= link_to settings_esign_path, class: 'flex items-center gap-2' do %>
                <%= svg_icon('zoom_check', class: 'w-5 h-5 flex-shrink-0 stroke-2 text-primary-content') %>
                <span class="whitespace-nowrap"><%= t('verify_pdf') %></span>
              <% end %>
            </li>
          <% end %>
          <% if Docuseal.multitenant? || current_user.role == 'superadmin' %>
            <li>
              <%= link_to Docuseal::CHATGPT_URL, target: 'blank', class: 'flex items-center gap-2' do %>
                <%= svg_icon('sparkles', class: 'w-5 h-5 flex-shrink-0 stroke-2 text-primary-content') %>
                <span class="whitespace-nowrap"><%= t('ask_ai') %></span>
              <% end %>
            </li>
          <% end %>
          <% if (can?(:manage, EncryptedConfig) && current_user == true_user) || (current_user != true_user && current_account.testing?) %>
            <li>
              <%= form_for '', url: testing_account_path, method: current_account.testing? ? :delete : :get, html: { class: 'w-full py-1' } do |f| %>
                <label class="flex items-center gap-2 w-full py-2 border-y border-base-300" for="testing_toggle">
                  <submit-form data-on="change" class="flex">
                    <%= f.check_box :testing_toggle, class: 'toggle', checked: current_account.testing?, style: 'height: 0.885rem; width: 1.35rem; --handleoffset: 0.395rem' %>
                  </submit-form>
                  <span class="whitespace-nowrap">
                    <%= t('test_mode') %>
                  </span>
                </label>
              <% end %>
            </li>
          <% end %>
          <li>
            <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false }, class: 'flex items-center gap-2' do %>
              <%= svg_icon('logout', class: 'w-5 h-5 flex-shrink-0 stroke-2 inline text-primary-content') %>
              <span class="whitespace-nowrap"><%= t('sign_out') %></span>
            <% end %>
          </li>
        </ul>
      </div>
      </div>
    <% else %>
    <div class="flex items-center justify-center space-x-2">
      <theme-toggle class="inline-flex items-center justify-center">
        <button type="button" class="theme-toggle-btn" aria-label="Toggle color theme" title="Toggle color theme">
          <span data-theme-icon="sun">
            <%= svg_icon('sun', class: 'w-5 h-5') %>
          </span>
          <span data-theme-icon="moon" class="hidden">
            <%= svg_icon('moon', class: 'w-5 h-5') %>
          </span>
        </button>
      </theme-toggle>
      <% if request.path != new_user_session_path && request.path != setup_index_path %>
        <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'font-medium text-lg' do %>
          <span class="flex items-center justify-center space-x-1">
            <%= svg_icon('login', class: 'w-6 h-6') %>
            <span><%= t('sign_in') %></span>
          </span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</header>
