<div class="settings-layout profile-settings-page templates-dashboard-page template-show-page">
  <div class="settings-main profile-settings-main templates-dashboard-main template-show-main">
    <%= render 'title', template: @template %>
    <% filter_params = params.permit(Submissions::Filter::ALLOWED_PARAMS).compact_blank %>
    <% is_show_tabs = @pagy.pages > 1 || params[:q].present? || params[:status].present? || filter_params.present? %>
    <% if @pagy.count.nil? || !@pagy.count.zero? || params[:q].present? || params[:status].present? || filter_params.present? %>
      <div class="tpl-show-submissions-header">
        <h2 class="tpl-show-section-title <%= 'hidden' if params[:q].present? %>">
          <%= t('submissions') %>
        </h2>
        <div class="tpl-show-submissions-toolbar">
          <% if params[:q].present? || params[:status].present? || filter_params.present? || @pagy.pages > 1 %>
            <%= render 'shared/search_input', title_selector: 'h2' %>
          <% end %>
          <%= link_to new_template_submissions_export_path(@template, params.permit(:q, *Submissions::Filter::ALLOWED_PARAMS)), class: 'tpl-show-action-btn tpl-show-action-btn--outline hidden md:inline-flex', data: { turbo_frame: 'modal' } do %>
            <%= svg_icon('download', class: 'w-5 h-5') %>
            <span><%= t('export') %></span>
          <% end %>
          <% if !@template.archived_at? && can?(:create, Submission) %>
            <%= link_to new_template_submission_path(@template), id: 'add_recipients_button', class: 'tpl-show-action-btn tpl-show-action-btn--primary base-button profile-settings-btn-primary', data: { turbo_frame: 'modal' } do %>
              <%= svg_icon('plus', class: 'w-5 h-5 stroke-2') %>
              <span><%= t('add_recipients_html') %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
    <% if is_show_tabs %>
      <div class="tpl-show-tabs">
        <div class="tpl-show-tabs-row flex-wrap">
          <a href="<%= url_for(params: request.query_parameters.except('status')) %>" class="tpl-show-tab ds-submissions-tab <%= 'tpl-show-tab--active' if params[:status].blank? %>">
            <div class="tpl-show-tab-label">
              <%= svg_icon('list', class: 'w-4 h-4') %>
              <span><%= t('all') %></span>
            </div>
            <% unless can?(:manage, :countless) %>
              <div class="tpl-show-tab-count submission-status-count">
                <%= params[:status].blank? && filter_params.blank? ? @pagy.count : @base_submissions.unscope(:group, :order).select(:id).distinct.count %>
              </div>
            <% end %>
          </a>
          <a href="<%= url_for(params: request.query_parameters.merge('status' => 'pending')) %>" class="tpl-show-tab ds-submissions-tab <%= 'tpl-show-tab--active' if params[:status] == 'pending' %>">
            <div class="tpl-show-tab-label">
              <%= svg_icon('clock', class: 'w-4 h-4') %>
              <span><%= t('pending') %></span>
            </div>
            <% unless can?(:manage, :countless) %>
              <div class="tpl-show-tab-count submission-status-count">
                <%= params[:status] == 'pending' && filter_params.blank? ? @pagy.count : @base_submissions.pending.unscope(:group, :order).select(:id).distinct.count %>
              </div>
            <% end %>
          </a>
          <a href="<%= url_for(params: request.query_parameters.merge('status' => 'completed')) %>" class="tpl-show-tab ds-submissions-tab <%= 'tpl-show-tab--active' if params[:status] == 'completed' %>">
            <div class="tpl-show-tab-label">
              <%= svg_icon('circle_check', class: 'w-4 h-4') %>
              <span><%= t('completed') %></span>
            </div>
            <% unless can?(:manage, :countless) %>
              <div class="tpl-show-tab-count submission-status-count">
                <%= params[:status] == 'completed' && filter_params.blank? ? @pagy.count : @base_submissions.completed.unscope(:group, :order).select(:id).distinct.count %>
              </div>
            <% end %>
          </a>
          <%= render 'submissions_filters/filter_button', filter_params: %>
          <% unless @template.archived_at? %>
            <%= render 'submissions_filters/actions', filter_params: filter_params.merge(template_id: @template.id) %>
          <% end %>
        </div>
        <div class="tpl-show-filters-row">
          <%= render 'submissions_filters/applied_filters', filter_params: %>
        </div>
      </div>
    <% end %>
    <% if @submissions.present? %>
      <div class="tpl-show-submissions-list space-y-4">
        <%= render partial: 'submission', collection: @submissions, locals: { template: @template } %>
      </div>
    <% else %>
      <div class="tpl-show-empty-state">
        <div class="tpl-show-empty-icon">
          <%= svg_icon('inbox', class: 'w-10 h-10') %>
        </div>
        <p class="tpl-show-empty-title">
          <%= t('there_are_no_submissions') %>
        </p>
        <% if @template.archived_at.blank? && params[:q].blank? && filter_params.blank? %>
          <p class="tpl-show-empty-subtitle templates-empty-subtitle"><%= t('send_an_invitation_to_fill_and_complete_the_form') %></p>
          <div class="tpl-show-empty-actions">
            <% if can?(:create, Submission) %>
              <%= link_to new_template_submission_path(@template, with_link: true), id: 'send_to_recipients_button', class: 'tpl-show-action-btn tpl-show-action-btn--primary', data: { turbo_frame: 'modal' } do %>
                <%= svg_icon('plus', class: 'w-5 h-5 stroke-2') %>
                <span><%= t('send_to_recipients') %></span>
              <% end %>
            <% end %>
            <% if Templates.filter_undefined_submitters(@template.submitters).size == 1 && @template.variables_schema.blank? %>
              <%= button_to start_form_path(@template.slug), params: { selfsign: true }, method: :put, class: 'tpl-show-action-btn tpl-show-action-btn--outline w-full md:w-auto', form: { style: 'display: inline', target: '_blank', data: { turbo: false } } do %>
                <%= svg_icon('writing', class: 'w-5 h-5') %>
                <span><%= t('sign_it_yourself') %></span>
              <% end %>
            <% else %>
              <%= link_to new_template_submission_path(@template, selfsign: true), id: 'sign_yourself_button', class: 'tpl-show-action-btn tpl-show-action-btn--outline', data: { turbo_frame: 'modal' } do %>
                <%= svg_icon('writing', class: 'w-5 h-5') %>
                <span><%= t('sign_it_yourself') %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
    <% view_archived_html = capture do %>
      <% if (can?(:manage, :countless) || @template.submissions.where.not(archived_at: nil).exists?) && !@template.archived_at? %>
        <div>
          <a href="<%= template_archived_index_path(@template) %>" class="tpl-show-archived-link"><%= t('view_archived') %></a>
        </div>
      <% end %>
    <% end %>
    <% if @pagy.pages > 1 %>
      <%= render 'shared/pagination', pagy: @pagy, items_name: 'submissions', left_additional_html: view_archived_html %>
    <% else %>
      <div class="mt-4">
        <%= view_archived_html %>
      </div>
    <% end %>
    <%= render 'shared/app_tour', type: 'template', next_page_path: settings_account_path(params.permit(:tour)) %>
  </div>
</div>
