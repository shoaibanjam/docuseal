<div class="absolute bottom-0 w-full cursor-pointer rounded-xl templates-dashboard-drag-overlay templates-dashboard-drag-overlay--folder hidden z-50 border-2 border-dashed" data-target="dashboard-dropzone.folderDropzone" style="<%= local_assigns[:style] %>">
  <div class="absolute top-0 right-0 left-0 bottom-0 flex justify-center p-2 items-center pointer-events-none">
    <div class="flex flex-col items-center text-center" data-target="dashboard-dropzone.toggleLoading">
      <span class="flex flex-col items-center">
        <span class="tpl-dropzone-icon-wrap" style="width:3.5rem;height:3.5rem;margin-bottom:0.75rem;">
          <%= svg_icon('folder_plus', class: 'tpl-dropzone-icon w-8 h-8') %>
        </span>
        <div class="tpl-dropzone-title" style="font-size:1rem;">
          <%= t('create_a_new_folder') %>
        </div>
      </span>
      <span class="flex flex-col items-center hidden" data-target="dashboard-dropzone.fileDropzoneLoading">
        <span class="tpl-dropzone-icon-wrap" style="width:3.5rem;height:3.5rem;margin-bottom:0.75rem;">
          <%= svg_icon('loader', class: 'w-8 h-8 animate-spin') %>
        </span>
        <div class="tpl-dropzone-title" style="font-size:1rem;">
          <%= t('loading') %>...
        </div>
      </span>
    </div>
  </div>
</div>
