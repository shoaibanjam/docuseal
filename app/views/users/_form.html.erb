<%= form_for user,
      html: { class: 'users-modal-form' },
      data: { turbo_frame: :_top } do |f| %>
  <div class="users-modal-editor">
    <p id="users-modal-description" class="signature-editor__lead users-modal-editor__lead">
      <% if user.new_record? %>
        <%= t(
              'users_modal_intro_new',
              default: 'Add their name, email, and role. They can finish activation from their inbox.'
            ) %>
      <% else %>
        <%= t(
              'users_modal_intro_edit',
              default: 'Update name, email, role, or security options for this user.'
            ) %>
      <% end %>
    </p>
    <div class="users-modal-editor__fields">
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="form-control">
          <%= f.label :first_name, t('first_name'), class: 'label' %>
          <%= f.text_field :first_name,
                required: true,
                class: 'base-input w-full',
                dir: 'auto',
                placeholder: t('users_placeholder_first_name', default: 'Alex'),
                aria: { describedby: 'users-modal-description' } %>
        </div>
        <div class="form-control">
          <%= f.label :last_name, t('last_name'), class: 'label' %>
          <%= f.text_field :last_name,
                required: true,
                class: 'base-input w-full',
                dir: 'auto',
                placeholder: t('users_placeholder_last_name', default: 'Rivera'),
                aria: { describedby: 'users-modal-description' } %>
        </div>
      </div>
      <div class="form-control">
        <%= f.label :email, t('email'), class: 'label' %>
        <%= f.email_field :email,
              required: true,
              class: 'base-input w-full',
              placeholder: t('users_placeholder_email', default: 'colleague@company.com'),
              aria: { describedby: 'users-modal-description' } %>
        <% if user.try(:pending_reconfirmation?) %>
          <label class="label">
            <span class="label-text-alt"><%= t('email_address_is_awaiting_confirmation_follow_the_link_in_the_email_to_confirm', email: f.object.unconfirmed_email) %></span>
          </label>
        <% end %>
        <% if user.persisted? && Accounts.can_send_emails?(current_account) %>
          <span class="label-text-alt mt-2 mx-1">
            <%= t('click_here_to_send_a_reset_password_email_html') %>
          </span>
        <% end %>
      </div>
      <% if user.new_record? && !Docuseal.multitenant? %>
        <div class="form-control">
          <%= f.label :password, t('password'), class: 'label' %>
          <%= f.password_field :password,
                class: 'base-input w-full',
                placeholder: t('users_placeholder_password', default: 'Set an initial password'),
                autocomplete: 'new-password',
                aria: { describedby: 'users-modal-description' } %>
        </div>
      <% end %>
      <% if f.object != current_user %>
        <% if user.otp_required_for_login %>
          <div class="form-control">
            <%= f.label :otp_required_for_login, t('two_factor_authentication'), class: 'label' %>
            <%= f.select :otp_required_for_login,
                  [[t('enabled'), true], [t('disabled'), false]],
                  { include_blank: false },
                  {
                    class: 'base-select w-full',
                    title: t('users_placeholder_2fa_select', default: 'Whether two-factor authentication is required at login'),
                    aria: { describedby: 'users-modal-description' }
                  } %>
          </div>
        <% end %>
        <%= render 'role_select', f: %>
      <% end %>
      <% if local_assigns[:extra_fields_html].present? %>
        <%= local_assigns[:extra_fields_html] %>
      <% end %>
    </div>
    <div class="signature-editor__actions users-modal-editor__actions">
      <button type="button" class="signature-editor__cancel btn btn-ghost" data-turbo-modal-close>
        <%= t('cancel', default: 'Cancel') %>
      </button>
      <%= f.button button_title, class: 'base-button signature-editor__save' %>
    </div>
  </div>
<% end %>
<% if user.persisted? %>
  <%= button_to nil, user_send_reset_password_path(user), id: 'resend_password_button', method: :put, class: 'hidden', data: { turbo_confirm: t('are_you_sure_'), turbo_frame: :_top } %>
<% end %>
