<div class="settings-layout profile-settings-page users-settings-page">
  <div class="settings-main profile-settings-main">
    <header class="settings-page-header profile-settings-header users-settings-header">
      <div class="settings-page-header-top">
        <div class="settings-page-avatar profile-settings-avatar users-settings-page__avatar" aria-hidden="true">
          <%= svg_icon('users', class: 'w-7 h-7 shrink-0') %>
        </div>
        <div class="profile-settings-header-text">
          <p class="users-settings-eyebrow">
            <%= t('users_settings_eyebrow', default: 'Workspace members') %>
          </p>
          <h1 class="ds-heading-2 profile-settings-title">
            <% if params[:status] == 'archived' %>
              <%= t('archived_users') %>
            <% elsif params[:status] == 'integration' %>
              <%= t('embedding_users') %>
            <% else %>
              <%= t('users') %>
            <% end %>
          </h1>
          <p class="settings-page-subtitle profile-settings-intro users-settings-intro">
            <% if params[:status] == 'archived' %>
              <%= t(
                    'users_settings_intro_archived',
                    default: 'Review archived accounts and restore them when someone should have access again.'
                  ) %>
            <% elsif params[:status] == 'integration' %>
              <%= t(
                    'users_settings_intro_integration',
                    default: 'Embedding-only and API-related accounts separate from regular workspace members.'
                  ) %>
            <% else %>
              <%= t(
                    'users_settings_intro',
                    default: 'Invite teammates, assign roles, and review sign-in activity.'
                  ) %>
            <% end %>
          </p>
        </div>
      </div>
    </header>

    <div class="users-settings-stack space-y-6">
      <% if params[:status].blank? %>
        <div class="users-settings-toolbar flex w-full flex-col gap-y-2 gap-x-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end">
          <% if can?(:create, User.new(account: current_account)) %>
            <%= render 'users/extra_buttons' %>
            <% if content_for(:add_user_button) %>
              <%= content_for(:add_user_button) %>
            <% else %>
              <%= link_to new_user_path, class: 'base-button profile-settings-btn-primary w-full sm:w-auto inline-flex items-center justify-center gap-2', data: { turbo_frame: 'modal' } do %>
                <%= svg_icon('plus', class: 'w-5 h-5') %>
                <span><%= t('new_user') %></span>
              <% end %>
            <% end %>
          <% else %>
            <div class="tooltip w-full sm:w-auto sm:min-w-0" data-tip="<%= t('contact_your_administrator_to_add_new_users') %>">
              <%= link_to '#', class: 'base-button profile-settings-btn-primary w-full sm:w-auto inline-flex items-center justify-center gap-2 btn-disabled pointer-events-none opacity-60 cursor-not-allowed', data: { turbo_frame: 'modal' } do %>
                <%= svg_icon('plus', class: 'w-5 h-5') %>
                <span><%= t('new_user') %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
      <section class="settings-card profile-settings-card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="table w-full table-lg overflow-hidden">
            <thead class="bg-base-200/80 users-table-head">
              <tr class="uppercase text-primary-content/80 text-xs tracking-wide users-table-head-row">
                <th>
                  <%= t('name') %>
                </th>
                <th>
                  <%= t('email') %>
                </th>
                <th>
                  <%= t('role') %>
                </th>
                <th>
                  <%= t('last_session') %>
                </th>
                <th class="text-right" width="1px">
                </th>
              </tr>
            </thead>
            <tbody>
              <% @users.each do |user| %>
                <tr scope="row" class="users-table-row">
                  <td>
                    <%= user.full_name %>
                  </td>
                  <td>
                    <% if user.try(:pending_reconfirmation?) %>
                      <%= user.unconfirmed_email %>
                      <br>
                      <span class="label-text-alt">(<%= t('unconfirmed') %>)</span>
                    <% else %>
                      <%= user.email %>
                    <% end %>
                  </td>
                  <td>
                    <span class="badge badge-info badge-outline whitespace-nowrap">
                      <%= t(user.role) %>
                    </span>
                  </td>
                  <td>
                    <%= user.current_sign_in_at ? l(user.current_sign_in_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) : '-' %>
                  </td>
                  <td class="flex items-center space-x-2 justify-end">
                    <% if params[:status].blank? && can?(:update, user) && user.archived_at.blank? %>
                      <%= link_to edit_user_path(user), class: 'btn btn-outline btn-xs', title: t('edit'), data: { turbo_frame: 'modal' } do %>
                        <%= t('edit') %>
                      <% end %>
                    <% end %>
                    <% if params[:status] != 'archived' && can?(:destroy, user) && user != current_user %>
                      <%= button_to user_path(user), method: :delete, class: 'btn btn-outline btn-error btn-xs', title: t('remove'), data: { turbo_confirm: t('are_you_sure_') } do %>
                        <%= t('remove') %>
                      <% end %>
                    <% end %>
                    <% if params[:status] == 'archived' && can?(:create, user) && user != current_user && user.archived_at? %>
                      <%= button_to user_path(user), method: :put, params: { user: { archived_at: nil } }, class: 'btn btn-outline btn-xs', title: t('unarchive'), data: { turbo_confirm: t('are_you_sure_') } do %>
                        <%= t('unarchive') %>
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>

      <% if @pagy.pages > 1 %>
        <%= render 'shared/pagination', pagy: @pagy, items_name: 'users', left_additional_html: render('bottom_links') %>
      <% else %>
        <div class="users-settings-bottom-links mt-2">
          <%= render 'bottom_links' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
