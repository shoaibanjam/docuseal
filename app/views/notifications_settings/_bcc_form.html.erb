<%= form_for config, url: settings_notifications_path, method: :post, html: { autocomplete: 'off', class: 'notifications-bcc-form' } do |f| %>
  <%= f.hidden_field :key %>
  <div class="form-control">
    <%= f.label :value, class: 'label' do %>
      <span class="flex items-center gap-1.5">
        <span>
          <%= t('completed_documents_notification_bcc_address') %>
        </span>
        <span class="tooltip" data-tip="<%= t('send_email_copy_with_completed_documents_to_a_specified_bcc_address') %>">
          <%= svg_icon('info_circle', class: 'w-4 h-4 text-current opacity-80') %>
        </span>
      </span>
    <% end %>
    <%= tag.input(
          type: 'email',
          multiple: true,
          name: 'account_config[value]',
          autocomplete: 'off',
          class: 'base-input',
          value: f.object.value,
          placeholder: t('notifications_placeholder_bcc', default: 'legal@company.com, ops@company.com')
        ) %>
  </div>
  <div class="settings-card-actions profile-settings-card-actions notifications-settings-save">
    <%= f.button button_title(
          title: t('save'),
          disabled_with: t('updating'),
          icon: svg_icon('save', class: 'w-4 h-4')
        ),
        class: 'base-button profile-settings-btn-primary w-full sm:w-auto flex items-center justify-center gap-2' %>
  </div>
<% end %>
